---
import { ClientRouter } from 'astro:transitions';

import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Văn Phòng Phẩm Long Hưng — VPP B2B",
  description = "Cung ứng văn phòng phẩm, chuyên nghiệp, tối ưu, an toàn — phục vụ doanh nghiệp.",
  ogImage = "/images/logo.png"
} = Astro.props;

const currentUrl = Astro.url.pathname;

const siteName = "Văn Phòng Phẩm Long Hưng";
const siteUrl = "https://vpplonghung.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteOgImage = new URL(ogImage, siteUrl).toString();

const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  alternateName: [
    "VPP Long Hưng",
    "Long Hưng Stationery",
    "vpplonghung.com"
  ],
  url: `${siteUrl}/`
};
---

<!DOCTYPE html>
<html lang="vi">
  <head>
   <!-- CookieHub -->
<script is:inline src="https://cdn.cookiehub.eu/c2/b251dc2a.js"></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    if (window.cookiehub && typeof window.cookiehub.load === "function") {
      window.cookiehub.load({});
    }
  });
</script>

<!-- Google tag (gtag.js) -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-M8CNP88TRZ"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){ window.dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('config', 'G-M8CNP88TRZ');
</script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={absoluteOgImage} />

<meta name="theme-color" content="#660011" />

<script
  type="application/ld+json"
  set:html={JSON.stringify(websiteStructuredData)}
/>

<link rel="icon" type="image/png" href="/images/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&family=Dancing+Script:wght@400;700&family=Noto+Serif+Display:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>

  <body data-page={currentUrl}>
    <slot />

    <script is:inline>
      (() => {
        const revealSelector = [
          "[data-reveal]",
          "[data-lh-reveal]",
          ".reveal",
          ".reveal-stagger > *",
          ".feature-item",
          ".feature-card",
          ".info-card",
          ".social-card",
          ".team-card",
          ".service-card",
          ".value-card",
          ".product-card",
          ".client-strip",
          ".clients-strip",
          ".form-wrapper",
          ".map-container"
        ].join(",");

        function setupSmoothScroll() {
          document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
            if (anchor.dataset.lhSmoothReady === "true") return;
            anchor.dataset.lhSmoothReady = "true";

            anchor.addEventListener("click", function (event) {
              const href = this.getAttribute("href");
              if (!href || href === "#") return;

              const target = document.querySelector(href);
              if (!target) return;

              event.preventDefault();
              target.scrollIntoView({
                behavior: "smooth",
                block: "start"
              });
            });
          });
        }

        function autoMarkRevealElements() {
          document
            .querySelectorAll("section:not(.hero):not(.products-hero)")
            .forEach((section) => {
              if (!section.hasAttribute("data-lh-reveal")) {
                section.setAttribute("data-lh-reveal", "");
              }
            });

          document
            .querySelectorAll(".grid, .products-grid, .social-grid, .team-grid")
            .forEach((grid) => {
              Array.from(grid.children).forEach((child, index) => {
                child.setAttribute("data-lh-reveal", "");
                child.classList.add("reveal-scale");

                const delay = Math.min(index, 8) * 70;
                child.style.setProperty("--reveal-delay", `${delay}ms`);
              });
            });
        }

        function runPageEntrance() {
          document.documentElement.classList.remove("lh-page-ready");

          // Force browser reflow so animation can restart on every page.
          void document.documentElement.offsetWidth;

          requestAnimationFrame(() => {
            document.documentElement.classList.add("lh-page-ready");
          });
        }

        function runRevealAnimations() {
          if (window.__lhRevealObserver) {
            window.__lhRevealObserver.disconnect();
          }

          const elements = document.querySelectorAll(revealSelector);

          if (!elements.length) return;

          if (!("IntersectionObserver" in window)) {
            elements.forEach((element) => {
              element.classList.add("is-visible");
            });
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            {
              threshold: 0.12,
              rootMargin: "0px 0px -8% 0px"
            }
          );

          elements.forEach((element) => {
            if (!element.classList.contains("is-visible")) {
              observer.observe(element);
            }
          });

          window.__lhRevealObserver = observer;
        }

        function initLongHungAnimations() {
          setupSmoothScroll();
          autoMarkRevealElements();
          runPageEntrance();
          runRevealAnimations();
        }

        if (!window.__lhAnimationBooted) {
          window.__lhAnimationBooted = true;

          document.addEventListener("astro:page-load", initLongHungAnimations);
          document.addEventListener("astro:after-swap", initLongHungAnimations);
        }

        initLongHungAnimations();
      })();
    </script>
  </body>
</html>