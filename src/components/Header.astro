---
// Header.astro - Responsive navigation with hamburger menu
import { Image } from 'astro:assets';

interface Props {
  currentPage?: string;
}

const { currentPage = '/' } = Astro.props;

const primaryNavLinks = [
  { title: 'Trang chủ', href: '/', slug: '/' },
  { title: 'Nhà sách', href: '/nha-sach', slug: '/nha-sach' },
  { title: 'Khách hàng doanh nghiệp', href: '/khach-hang', slug: '/khach-hang' },
  { title: 'Sản phẩm', href: '/san-pham', slug: '/san-pham' }
];

const secondaryNavLinks = [
  { title: 'Về chúng tôi', href: '/ve-chung-toi', slug: '/ve-chung-toi' },
  { title: 'Chính sách', href: '/chinh-sach', slug: '/chinh-sach' },
  { title: 'Liên hệ', href: '/lien-he', slug: '/lien-he' }
];

const allNavLinks = [...primaryNavLinks, ...secondaryNavLinks];

---

<header class="header">
  <nav class="navbar">
    <div class="container navbar-container">
      <div class="logo">
        <a href="/">
          <img src="/images/logo.webp" alt="VPP Long Hưng" class="logo-img" />
          <span class="logo-text">Văn phòng phẩm Long Hưng</span>
        </a>
      </div>

      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-menu" id="navMenu">
        {allNavLinks.map(link => (
          <li class="nav-item" data-nav-item>
            <a
              href={link.href}
              class={`nav-link ${currentPage === link.slug || (link.slug !== '/' && currentPage.startsWith(link.slug)) ? 'active' : ''}`}
            >
              {link.title}
            </a>
          </li>
        ))}
        
        <li class="nav-item mobile-cta">
          <a href="/lien-he" class="btn btn-cta">Tư vấn Ngay</a>
        </li>
      </ul>

      <div class="header-cta desktop-cta">
        <a href="/lien-he" class="btn btn-cta">Tư vấn Ngay</a>
      </div>
    </div>
  </nav>
</header>

<style>
  .header {
    background-color: var(--color-white);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .navbar {
    width: 100%;
  }

  .navbar-container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) var(--spacing-lg);
    gap: var(--spacing-lg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex: 0 0 auto;
    min-width: 0;
  }

  .logo a {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    text-decoration: none;
    color: var(--color-brown);
  }

  .logo-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-brown);
    line-height: 1.2;
    white-space: normal;
  }

  .nav-menu {
    display: flex;
    list-style: none;
    gap: 1rem;
    align-items: center;
    margin: 0;
    padding: 0;
    flex: 1 1 500px;
    justify-content: center;
    flex-wrap: wrap;
    min-width: 0;
    max-width: 100%;
  }

  .nav-item {
    position: relative;
    white-space: nowrap;
  }

  .nav-link,
  .dropdown-toggle {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none !important;
    transition: color 0.3s ease-in-out;
    padding: var(--spacing-sm) 0;
    border-bottom: none;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  .dropdown-toggle {
    padding: var(--spacing-sm) 0;
  }

  .nav-link:hover,
  .dropdown-toggle:hover,
  .dropdown-toggle:focus {
    color: var(--color-primary);
    text-decoration: none !important;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-gold);
    transition: width 0.3s ease-in-out;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active,
  .dropdown-toggle.active {
    color: var(--color-primary);
    text-decoration: none !important;
  }

  .nav-link.active::after {
    width: 100%;
    background-color: var(--color-gold);
  }

  .nav-dropdown {
    position: relative;
  }

  .dropdown-arrow {
    transition: transform 0.2s ease;
  }

  .nav-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.45rem);
    left: 0;
    min-width: 200px;
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-md);
    padding: 0.5rem 0;
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 200;
  }

  .nav-dropdown.open .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-menu li {
    min-width: 100%;
  }

  .dropdown-menu a {
    display: block;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .dropdown-menu a:hover {
    color: var(--color-primary);
    background-color: rgba(102, 0, 17, 0.05);
  }

  .header-cta {
    flex-shrink: 0;
    margin-left: var(--spacing-lg);
  }

  .btn-cta {
    padding: var(--spacing-sm) var(--spacing-lg);
    font-size: 0.95rem;
    white-space: nowrap;
  }

  /* Ẩn nút CTA mobile khi đang ở trên PC */
  .mobile-cta {
    display: none;
  }

  /* Hamburger Menu (Mobile) */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--spacing-sm);
  }

  .hamburger span {
    width: 24px;
    height: 3px;
    background-color: var(--color-brown);
    transition: all var(--transition-normal, 0.3s); /* Thêm fallback 0.3s */
    border-radius: 2px;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(10px, 10px);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  /* --- GIAO DIỆN MOBILE --- */
  @media (max-width: 768px) {
    .navbar-container {
      padding: var(--spacing-md);
    }

    .hamburger {
      display: flex;
      order: 2;
    }

    /* Ẩn nút CTA trên thanh ngang để nhường chỗ cho Logo */
    .desktop-cta {
      display: none;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--color-white);
      flex-direction: column;
      gap: var(--spacing-md);
      padding: 0 var(--spacing-lg);
      justify-content: flex-start;
      max-height: 0;
      overflow: hidden;
      visibility: hidden;
      opacity: 0;
      transition: all 0.4s ease-in-out;
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
    }

    .nav-menu.active {
      max-height: 100vh;
      padding: var(--spacing-lg);
      visibility: visible;
      opacity: 1;
    }

    .nav-link,
    .dropdown-toggle {
      width: 100%;
      padding: var(--spacing-sm) 0;
      display: block;
      text-align: left;
    }

    .nav-dropdown {
      width: 100%;
    }

    .dropdown-menu {
      position: static;
      transform: none;
      opacity: 0;
      visibility: hidden;
      max-height: 0;
      overflow: hidden;
      border: none;
      box-shadow: none;
      padding: 0;
      transition: opacity 0.2s ease, max-height 0.2s ease, visibility 0.2s ease;
    }

    .nav-dropdown.open .dropdown-menu {
      opacity: 1;
      visibility: visible;
      max-height: 400px;
    }

    .dropdown-menu a {
      padding-left: 1rem;
    }

    .mobile-cta {
      display: block;
      width: 100%;
      margin-top: var(--spacing-sm);
      padding-top: var(--spacing-md);
      border-top: 1px solid #eee;
    }

    .mobile-cta .btn-cta {
      width: 100%;
      display: block;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .logo-text {
      display: none;
    }

    .nav-menu {
      gap: var(--spacing-md);
    }
  }
</style>

<script>
  const initMenu = () => {
    const hamburger = document.getElementById('hamburger');
    const navMenu = document.getElementById('navMenu');

    if (hamburger && navMenu) {
      // 1. Reset trạng thái khi chuyển trang
      hamburger.classList.remove('active');
      navMenu.classList.remove('active');

      // 2. Clone node để tránh lỗi dính 2 lần sự kiện click của Astro
      const newHamburger = hamburger.cloneNode(true);
      hamburger.parentNode?.replaceChild(newHamburger, hamburger);
      
      const btn = document.getElementById('hamburger');
      
      // 3. Gắn sự kiện bật/tắt menu
      btn?.addEventListener('click', () => {
        btn.classList.toggle('active');
        navMenu.classList.toggle('active');
      });

      // 4. Đóng menu khi người dùng bấm vào một link bất kỳ
      const navLinks = navMenu.querySelectorAll('.nav-link, .btn-cta');
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          btn?.classList.remove('active');
          navMenu.classList.remove('active');
        });
      });
    }
  };

  // Chạy lần đầu khi load trang
  initMenu();

  // Đảm bảo chạy lại sau khi ViewTransitions chuyển trang (nếu có dùng)
  document.addEventListener('astro:after-swap', initMenu);

  const initDropdowns = () => {
    const dropdownToggles = document.querySelectorAll('[data-dropdown] .dropdown-toggle');

    dropdownToggles.forEach((toggle) => {
      const dropdownItem = toggle.closest('[data-dropdown]');
      const dropdownMenu = dropdownItem?.querySelector('.dropdown-menu');

      if (!dropdownItem || !dropdownMenu) return;

      toggle.addEventListener('click', () => {
        const isOpen = dropdownItem.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    });
  };

  initDropdowns();
</script>