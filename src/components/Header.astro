---
// Header.astro - Responsive navigation with hamburger menu
interface Props {
  currentPage?: string;
}

const { currentPage = '/' } = Astro.props;

const navLinks = [
  { title: 'Trang chủ', href: '/', slug: '/' },
  { title: 'Nhà sách', href: '/nha-sach', slug: '/nha-sach' },
  { title: 'Khách hàng doanh nghiệp', href: '/khach-hang', slug: '/khach-hang', hideAt: '768' },
  { title: 'Sản phẩm', href: '/san-pham', slug: '/san-pham', hideAt: '992' }
];

const dropdownLinks = [
  { title: 'Về chúng tôi', href: '/ve-chung-toi', slug: '/ve-chung-toi', showAt: 'always' },
  { title: 'Chính sách', href: '/chinh-sach', slug: '/chinh-sach', showAt: 'always' },
  { title: 'Liên hệ', href: '/lien-he', slug: '/lien-he', showAt: 'always' },
];

---

<header class="header">
  <nav class="navbar">
    <div class="container navbar-container">
      <div class="logo">
        <a href="/">
          <img src="/images/logo.webp" alt="VPP Long Hưng" class="logo-img" />
          <span class="logo-text">Văn phòng phẩm Long Hưng</span>
        </a>
      </div>

      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-menu" id="navMenu">
        {navLinks.map(link => (
          <li class={`nav-item ${link.hideAt ? `hide-at-${link.hideAt}` : ''}`} data-nav-item>
            <a
              href={link.href}
              class={`nav-link ${currentPage === link.slug || (link.slug !== '/' && currentPage.startsWith(link.slug)) ? 'active' : ''}`}
            >
              {link.title}
            </a>
          </li>
        ))}

        <li class="nav-item nav-dropdown" data-dropdown>
          <button type="button" class="dropdown-toggle" aria-expanded="false" aria-label="Thông tin">
            <span class="dropdown-label">Thông tin</span>
            <span class="dropdown-icon" aria-hidden="true">
              <span class="dropdown-icon-line dropdown-icon-line--left"></span>
              <span class="dropdown-icon-line dropdown-icon-line--right"></span>
            </span>
          </button>
          <ul class="dropdown-menu">
            {dropdownLinks.map(link => (
              <li class={`dropdown-item ${link.showAt !== 'always' ? `show-at-${link.showAt}` : ''}`}>
                <a
                  href={link.href}
                  class={`nav-link ${currentPage === link.slug || (link.slug !== '/' && currentPage.startsWith(link.slug)) ? 'active' : ''}`}
                >
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </li>
        
        <li class="nav-item mobile-cta">
          <a href="/lien-he" class="btn btn-cta">Tư vấn Ngay</a>
        </li>
      </ul>

      <div class="header-cta desktop-cta">
        <a href="/lien-he" class="btn btn-cta">Tư vấn Ngay</a>
      </div>
    </div>
  </nav>
</header>

<style>
  .header {
    background-color: var(--color-white);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 1000;
    --mobile-nav-offset: 76px;
  }

  body.nav-open {
    overflow: hidden;
  }

  .navbar {
    width: 100%;
  }

  .navbar-container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex: 0 0 auto;
    min-width: 0;
  }

  .logo a {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    text-decoration: none;
    color: var(--color-brown);
  }

  .logo-img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-brown);
    line-height: 1.2;
    white-space: normal;
  }

  .nav-menu {
    display: flex;
    list-style: none;
    gap: 1rem;
    align-items: flex-end;
    margin: 0;
    padding: 0;
    flex: 1 1 500px;
    justify-content: flex-end;
    flex-wrap: wrap;
    min-width: 0;
    max-width: 100%;
  }

  .nav-item {
    position: relative;
    white-space: nowrap;
  }

  .nav-link,
  .dropdown-toggle {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none !important;
    transition: color 0.3s ease-in-out;
    padding: 0.45rem 0;
    border-bottom: none;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  .dropdown-toggle {
    padding: 0.25rem 0.25rem;
    min-width: 40px;
    min-height: 40px;
  }

  .dropdown-label {
    display: none;
  }

  .dropdown-icon {
    display: inline-flex;
    position: relative;
    width: 18px;
    height: 18px;
    align-items: center;
    justify-content: center;
  }

  .dropdown-icon-line {
    position: absolute;
    width: 8px;
    height: 2px;
    border-radius: 999px;
    background-color: currentColor;
    top: 50%;
    left: 50%;
    transform-origin: center;
  }

  .dropdown-icon-line--left {
    transform: translate(-7px, -1px) rotate(45deg);
  }

  .dropdown-icon-line--right {
    transform: translate(-1px, -1px) rotate(-45deg);
  }

  .nav-link:hover,
  .dropdown-toggle:hover,
  .dropdown-toggle:focus {
    color: var(--color-primary);
    text-decoration: none !important;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-gold);
    transition: width 0.3s ease-in-out;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active,
  .dropdown-toggle.active {
    color: var(--color-primary);
    text-decoration: none !important;
  }

  .nav-link.active::after {
    width: 100%;
    background-color: var(--color-gold);
  }

  .nav-dropdown {
    position: relative;
  }

  .dropdown-arrow {
    transition: transform 0.2s ease;
  }

  .nav-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.45rem);
    left: 50%;
    min-width: 200px;
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-md);
    padding: 0.5rem 0;
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, 6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 200;
  }

  .nav-dropdown.open .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }

  .dropdown-menu li {
    min-width: 100%;
    display: block;
  }

  .dropdown-menu a {
    display: block;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.4;
    white-space: normal;
  }

  .dropdown-menu a:hover {
    color: var(--color-primary);
    background-color: rgba(102, 0, 17, 0.05);
  }

  .header-cta {
    flex-shrink: 0;
    margin-left: var(--spacing-lg);
  }

  .btn-cta {
    padding: 0.8rem 1.25rem;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  /* Ẩn nút CTA mobile khi đang ở trên PC */
  .mobile-cta {
    display: none;
  }

  .hide-at-992 {
    display: list-item;
  }

  .hide-at-768 {
    display: list-item;
  }

  .show-at-992,
  .show-at-768 {
    display: none;
  }

  .dropdown-item {
    display: block;
  }

  .dropdown-item.show-at-992,
  .dropdown-item.show-at-768 {
    display: none;
  }

  /* Hamburger Menu (Mobile) */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--spacing-sm);
  }

  .hamburger span {
    width: 24px;
    height: 3px;
    background-color: var(--color-brown);
    transition: all var(--transition-normal, 0.3s); /* Thêm fallback 0.3s */
    border-radius: 2px;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(10px, 10px);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  /* --- GIAO DIỆN MOBILE --- */
  @media (max-width: 768px) {
    .navbar-container {
      padding: var(--spacing-md);
    }

    .hamburger {
      display: flex;
      order: 2;
    }

    /* Ẩn nút CTA trên thanh ngang để nhường chỗ cho Logo */
    .desktop-cta {
      display: none;
    }

    .nav-menu {
      position: fixed;
      inset: 0;
      background-color: var(--color-white);
      flex-direction: column;
      gap: 0.25rem;
      padding: calc(var(--mobile-nav-offset) + 0.85rem) 0.85rem calc(1rem + env(safe-area-inset-bottom));
      justify-content: flex-start;
      height: 100dvh;
      max-height: 100dvh;
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
      visibility: hidden;
      opacity: 0;
      transition: all 0.4s ease-in-out;
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
      border-radius: 0;
    }

    .nav-menu.active {
      max-height: none;
      padding: calc(var(--mobile-nav-offset) + 0.85rem) 0.85rem calc(1rem + env(safe-area-inset-bottom));
      visibility: visible;
      opacity: 1;
    }

    .nav-link,
    .dropdown-toggle {
      width: 100%;
      padding: 0.9rem 0.15rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      text-align: left;
      gap: 0.75rem;
    }

    .nav-dropdown {
      width: 100%;
    }

    .nav-item {
      width: 100%;
      white-space: normal;
    }

    .nav-menu .hide-at-992,
    .nav-menu .hide-at-768 {
      display: block;
    }

    .nav-menu .show-at-992,
    .nav-menu .show-at-768 {
      display: block;
    }

    .dropdown-toggle {
      width: 100%;
      min-height: auto;
      pointer-events: none;
      padding-bottom: 0.45rem;
      border-bottom: 1px solid rgba(81, 33, 11, 0.12);
    }

    .dropdown-label {
      display: inline-flex;
      align-items: center;
      font-size: 1rem;
      font-weight: 600;
    }

    .dropdown-icon {
      display: none;
    }

    .dropdown-menu {
      display: block;
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      max-height: none;
      overflow: visible;
      border: none;
      box-shadow: none;
      padding: 0.2rem 0 0.1rem 0.95rem;
      transition: none;
      width: 100%;
    }

    .nav-dropdown.open .dropdown-menu {
      display: block;
    }

    .dropdown-menu li {
      width: 100%;
    }

    .dropdown-menu li + li {
      border-top: 1px solid rgba(81, 33, 11, 0.08);
      margin-top: 0.15rem;
      padding-top: 0.15rem;
    }

    .dropdown-menu a {
      padding: 0.7rem 0.35rem 0.7rem 0.75rem;
      border-radius: 8px;
    }

    .mobile-cta {
      display: block;
      width: 100%;
      margin-top: var(--spacing-sm);
      padding-top: var(--spacing-md);
      border-top: 1px solid #eee;
    }

    .mobile-cta .btn-cta {
      width: 100%;
      display: block;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .logo-text {
      display: none;
    }

    .nav-menu {
      gap: 0.75rem;
    }

    .show-at-992,
    .show-at-768 {
      display: block;
    }
  }

  @media (max-width: 992px) {
    .dropdown-item.show-at-992 {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .dropdown-item.show-at-768 {
      display: block;
    }
  }

  @media (max-width: 992px) {
    .hide-at-992 {
      display: none;
    }
    .show-at-992 {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .hide-at-768 {
      display: none;
    }
    .show-at-768 {
      display: block;
    }
  }
</style>

<script>
  const closeAllDropdowns = () => {
    document.querySelectorAll('[data-dropdown].open').forEach((item) => {
      item.classList.remove('open');
      const toggle = item.querySelector('.dropdown-toggle');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  };

  const initMenu = () => {
    const hamburger = document.getElementById('hamburger');
    const navMenu = document.getElementById('navMenu');

    if (hamburger && navMenu) {
      // 1. Reset trạng thái khi chuyển trang
      hamburger.classList.remove('active');
      navMenu.classList.remove('active');

      // 2. Clone node để tránh lỗi dính 2 lần sự kiện click của Astro
      const newHamburger = hamburger.cloneNode(true);
      hamburger.parentNode?.replaceChild(newHamburger, hamburger);
      
      const btn = document.getElementById('hamburger');
      
      // 3. Gắn sự kiện bật/tắt menu
      btn?.addEventListener('click', () => {
        btn.classList.toggle('active');
        navMenu.classList.toggle('active');
        document.body.classList.toggle('nav-open', navMenu.classList.contains('active'));
        if (!navMenu.classList.contains('active')) {
          closeAllDropdowns();
        }
      });

      // 4. Đóng menu khi người dùng bấm vào một link bất kỳ
      const navLinks = navMenu.querySelectorAll('.nav-link, .btn-cta');
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          btn?.classList.remove('active');
          navMenu.classList.remove('active');
          document.body.classList.remove('nav-open');
          closeAllDropdowns();
        });
      });
    }
  };

  // Chạy lần đầu khi load trang
  initMenu();

  // Đảm bảo chạy lại sau khi ViewTransitions chuyển trang (nếu có dùng)
  document.addEventListener('astro:after-swap', initMenu);

  const initDropdowns = () => {
    const navMenu = document.getElementById('navMenu');
    const dropdownToggles = document.querySelectorAll('[data-dropdown] .dropdown-toggle');

    dropdownToggles.forEach((toggle) => {
      if (toggle.dataset.bound === 'true') return;
      toggle.dataset.bound = 'true';

      const dropdownItem = toggle.closest('[data-dropdown]');
      const dropdownMenu = dropdownItem?.querySelector('.dropdown-menu');

      if (!dropdownItem || !dropdownMenu) return;

      toggle.addEventListener('click', (event) => {
        event.stopPropagation();
        const shouldOpen = !dropdownItem.classList.contains('open');
        closeAllDropdowns();
        if (shouldOpen) {
          dropdownItem.classList.add('open');
        }
        const isOpen = dropdownItem.classList.contains('open');
        toggle.setAttribute('aria-expanded', String(isOpen));
        if (isOpen) {
          navMenu?.scrollTo({ top: navMenu.scrollHeight, behavior: 'smooth' });
        }
      });

      dropdownMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          closeAllDropdowns();
        });
      });
    });

    if (!document.body.dataset.dropdownBound) {
      document.body.dataset.dropdownBound = 'true';

      document.addEventListener('click', (event) => {
        if (!(event.target instanceof Element)) return;
        if (!event.target.closest('[data-dropdown]')) {
          closeAllDropdowns();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeAllDropdowns();
        }
      });
    }
  };

  initDropdowns();
  document.addEventListener('astro:after-swap', initDropdowns);
</script>