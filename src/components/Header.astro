---
// Header.astro - Navigation with 5 links + CTA button
import { Image } from 'astro:assets';

interface Props {
  currentPage?: string;
}

const { currentPage = '/' } = Astro.props;

const navLinks = [
  { title: 'Trang chủ', href: '/', slug: '/' },
  { title: 'Nhà sách', href: '/nha-sach', slug: '/nha-sach' },
  { title: 'Khách hàng doanh nghiệp', href: '/khach-hang', slug: '/khach-hang' },
  { title: 'Về chúng tôi', href: '/ve-chung-toi', slug: '/ve-chung-toi' },
  { title: 'Liên hệ', href: '/lien-he', slug: '/lien-he' },
  { title: 'Sản phẩm', href: '/san-pham', slug: '/san-pham' }
];
---

<header class="header">
  <nav class="navbar">
    <div class="container navbar-container">
      <!-- Logo -->
      <div class="logo">
        <a href="/">
          <img src="/images/logo.png" alt="VPP Long Hưng" class="logo-img" />
         <span class="logo-text">Văn phòng phẩm <br> Long Hưng</span>
                   
        </a>
      </div>

      <!-- Hamburger Menu (Mobile) -->
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <!-- Navigation Menu -->
      <ul class="nav-menu" id="navMenu">
        {navLinks.map(link => (
          <li class="nav-item">
            <a
              href={link.href}
              class={`nav-link ${currentPage === link.slug ? 'active' : ''}`}
            >
              {link.title}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA Button -->
      <div class="header-cta">
        <a href="/lien-he" class="btn btn-cta">Tư vấn Ngay</a>
      </div>
    </div>
  </nav>
</header>

<style>
  .header {
    background-color: var(--color-white);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .navbar {
    width: 100%;
  }

  .navbar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) var(--spacing-lg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-shrink: 0;
  }

  .logo a {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    text-decoration: none;
    color: var(--color-brown);
  }

  .logo-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-brown);
  }

  .nav-menu {
    display: flex;
    list-style: none;
    gap: var(--spacing-lg);
    align-items: center;
    margin: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none !important;
    transition: color 0.3s ease-in-out;
    padding: var(--spacing-sm) 0;
    border-bottom: none;
    position: relative;
    display: inline-block;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-gold);
    transition: width 0.3s ease-in-out;
  }

  .nav-link:hover {
    color: var(--color-primary);
    text-decoration: none !important;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--color-primary);
    text-decoration: none !important;
  }

  .nav-link.active::after {
    width: 100%;
    background-color: var(--color-gold);
  }

  .header-cta {
    flex-shrink: 0;
    margin-left: var(--spacing-lg);
  }

  .btn-cta {
    padding: var(--spacing-sm) var(--spacing-lg);
    font-size: 0.95rem;
    white-space: nowrap;
  }

  /* Hamburger Menu (Mobile) */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--spacing-sm);
  }

  .hamburger span {
    width: 24px;
    height: 3px;
    background-color: var(--color-brown);
    transition: all var(--transition-normal);
    border-radius: 2px;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(10px, 10px);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .navbar-container {
      padding: var(--spacing-md);
      gap: var(--spacing-md);
    }

    .hamburger {
      display: flex;
      order: 2;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--color-white);
      flex-direction: column;
      gap: var(--spacing-md);
      padding: var(--spacing-lg);
      justify-content: flex-start;
      max-height: 0;
      overflow: hidden;
      transition: max-height var(--transition-normal);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
    }

    .nav-menu.active {
      max-height: 400px;
    }

    .nav-link {
      width: 100%;
      padding: var(--spacing-sm) 0;
    }

    .header-cta {
      margin-left: 0;
      width: 100%;
    }

    .btn-cta {
      width: 100%;
      display: block;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .logo-text {
      display: none;
    }

    .nav-menu {
      gap: var(--spacing-md);
    }
  }
</style>

<script>
  // Mobile menu toggle
  const hamburger = document.getElementById('hamburger');
  const navMenu = document.getElementById('navMenu');

  if (hamburger && navMenu) {
    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navMenu.classList.toggle('active');
    });

    // Close menu when link is clicked
    const navLinks = navMenu.querySelectorAll('.nav-link');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navMenu.classList.remove('active');
      });
    });
  }
</script>
