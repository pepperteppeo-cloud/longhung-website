          <li><a href="/chinh-sach/bao-hanh">Bảo hành</a></li>
          <li><a href="/dieu-khoan-giao-dich">Điều khoản</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="footer-section">
        <p class="footer-title">Liên hệ</p>
        <div class="contact-info">
          <p>
            <strong>Địa chỉ:</strong><br />
            <a href="https://maps.app.goo.gl/SiMsFZXzmaTaW9W1A" target="_blank" rel="noopener noreferrer">
              LK03-07, Roman Plaza, Đại Mỗ, Hà Nội, Việt Nam
