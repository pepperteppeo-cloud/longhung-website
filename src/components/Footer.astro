    <!-- Divider -->
    <div class="footer-divider"></div>

    <!-- Legal & Copyright -->
    <div class="footer-bottom">
      <div class="legal-text">
        <p class="text-small">
          <strong>Tên doanh nghiệp:</strong> Công ty TNHH Văn phòng phẩm Long Hưng
