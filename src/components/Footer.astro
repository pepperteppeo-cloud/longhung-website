      <!-- Quick Links -->
      <div class="footer-section">
        <p class="footer-title">Liên kết nhanh</p>
        <ul class="footer-links">
          <li><a href="/">Trang chủ</a></li>
          <li><a href="/nha-sach">Nhà sách</a></li>
          <li><a href="/khach-hang">Khách hàng</a></li>
