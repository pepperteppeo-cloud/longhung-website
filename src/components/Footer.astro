          <a
            href="https://zalo.me/403362719590961487"
            target="_blank"
            rel="noopener noreferrer"
            title="Zalo"
            aria-label="Zalo"
          >
            <img src="/images/icon-social-zalo.webp" alt="" class="social-icon" loading="lazy" decoding="async" />
          </a>
          <a
            href="https://www.tiktok.com/@nhasachlonglung"
            target="_blank"
            rel="noopener noreferrer"
            title="TikTok"
            aria-label="TikTok"
