---
interface Props {
  src: string;
  alt: string;
  ratio?: '16-9' | '4-3' | '1-1' | '3-2' | '2-1';
  class?: string;
  title?: string;
}

const { src, alt, ratio = '16-9', class: className = '', title } = Astro.props;
const ratioClass = ratio.replace(':', '-');
---

<div class={`image-container image-container--${ratioClass} ${className}`}>
  <img 
    src={src} 
    alt={alt} 
    title={title || alt}
    loading="lazy" 
  />
</div>

<style>
  .image-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .image-container--16-9 {
    aspect-ratio: 16 / 9;
  }

  .image-container--4-3 {
    aspect-ratio: 4 / 3;
  }

  .image-container--1-1 {
    aspect-ratio: 1 / 1;
  }

  .image-container--3-2 {
    aspect-ratio: 3 / 2;
  }

  .image-container--2-1 {
    aspect-ratio: 2 / 1;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.3s ease-in-out;
  }

  .image-container:hover img {
    transform: scale(1.05);
  }
</style>
