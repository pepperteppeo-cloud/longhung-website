---
// src/pages/lien-he.astro - Page 4: Liên hệ
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const contactCards = [
  {
    icon: '/images/icon-contact-location.webp',
    title: 'Địa Chỉ',
    content: 'LK03-07, Roman Plaza, Đại Mỗ, Hà Nội, Việt Nam',
    href: 'https://maps.app.goo.gl/rm11siBErfPbpHrq8'
  },
  {
    icon: '/images/icon-contact-phone.webp',
    title: 'Điện Thoại',
    content: '0389.023.720 — Mr. Huy / 0353.839.500 — Nhà sách',
    href: 'tel:+84389023720'
  },
  {
    icon: '/images/icon-contact-email.webp',
    title: 'Email',
    content: 'kinhdoanh@vpplonghung.com / hotro@vpplonghung.com',
    href: 'mailto:kinhdoanh@vpplonghung.com'
  },
  {
    icon: '/images/icon-contact-time.webp',
    title: 'Giờ Làm Việc',
    content: 'Thứ 2 - Chủ Nhật: 8:00 - 22:00',
    href: ''
  }
];

const socialLinks = [
  {
    icon: '/images/icon-social-facebook.webp',
    title: 'Facebook',
    text: 'Theo dõi cập nhật hàng ngày',
    href: 'https://web.facebook.com/profile.php?id=61580711382370'
  },
  {
    icon: '/images/icon-social-instagram.webp',
    title: 'Instagram',
    text: 'Xem ảnh sản phẩm và khuyến mãi',
    href: 'https://www.instagram.com/longhung.quantri/'
  },
  {
    icon: '/images/icon-social-zalo.webp',
    title: 'Zalo',
    text: 'Liên hệ nhanh qua Zalo',
    href: 'https://zalo.me/403362719590961487'
  },
  {
    icon: '/images/icon-social-tiktok.webp',
    title: 'TikTok',
    text: 'Xem video và hoạt động mới',
    href: 'https://www.tiktok.com/@nhasachlonglung'
  }
];

const mapEmbedSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4457.595646593065!2d105.7779734!3d20.9857244!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x313453a56e4f1e1b%3A0xc8a647e05f3fabd7!2zSGnhu4d1IHPDoWNoIExvbmcgSMawbmc!5e1!3m2!1svi!2s!4v1780030444520!5m2!1svi!2s";
---

<Layout
  title="Liên Hệ — Văn Phòng Phẩm Long Hưng"
  description="Liên hệ với Văn Phòng Phẩm Long Hưng. Địa chỉ, điện thoại, email, bản đồ và biểu mẫu tư vấn."
>
  <Header currentPage="/lien-he" />

  <!-- Hero Section -->
  <!-- Khi có banner riêng cho trang liên hệ, chỉ cần đổi đường dẫn ảnh bên dưới. -->
  <section class="hero hero-contact hero-page" style="background-image: url('/images/hero-vpp.webp')">
    <div class="hero-inner">
      <div class="page-hero-content">
        <h1>Liên Hệ Với Chúng Tôi</h1>
        <p class="page-hero-description">Long Hưng luôn sẵn sàng tư vấn, báo giá và hỗ trợ nhu cầu văn phòng phẩm của bạn.</p>
      </div>
    </div>
  </section>

  <!-- Contact Info Panel -->
  <section class="contact-info-section">
    <div class="container">
      <div class="grid grid-4 contact-grid reveal-stagger">
        {contactCards.map((card) => (
          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <img src={card.icon} alt="" loading="lazy" decoding="async" />
            </div>
            <h3>{card.title}</h3>
            {card.href ? (
              <p>
                <a href={card.href} target={card.href.startsWith('http') ? '_blank' : undefined} rel={card.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                  {card.content}
                </a>
              </p>
            ) : (
              <p>{card.content}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="contact-section" class="contact-page-form reveal" data-reveal>
    <ContactForm
      title="Gửi Tin Nhắn"
      subtitle="Để lại thông tin và chúng tôi sẽ liên hệ lại trong vòng 24 giờ"
    />
  </section>

  <!-- Google Maps -->
  <section class="map-section reveal" data-reveal>
    <div class="map-container">
      <iframe
        src={mapEmbedSrc}
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Bản đồ Nhà sách Long Hưng"
      ></iframe>
    </div>
  </section>

  <!-- Social Links -->
  <section class="social-section reveal" data-reveal>
    <div class="container">
      <h2 class="section-title text-center mb-4">Theo Dõi Chúng Tôi</h2>

      <div class="social-grid reveal-stagger">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-card"
          >
            <div class="social-icon" aria-hidden="true">
              <img src={social.icon} alt="" loading="lazy" decoding="async" />
            </div>
            <h3>{social.title}</h3>
            <p>{social.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>