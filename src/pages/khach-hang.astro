---
// src/pages/khach-hang.astro - Page 3: Khách hàng doanh nghiệp
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const teamMembers = [
  {
    image: '/images/team-huy.webp',
    name: 'Mr. Trương Mạnh Huy',
    position: 'Quản lý & Trưởng Phòng Kinh Doanh',
    bio: 'Tôi là người trực tiếp đồng hành, hỗ trợ và mang đến cho bạn những sản phẩm, dịch vụ có chất lượng và giá thành tốt nhất.',
    phone: '+84389023720',
    button: 'Gọi Mr. Huy'
  },
  {
    image: '/images/team-vinh.webp',
    name: 'Mr. Tiêu Phúc Vinh',
    position: 'Phụ trách Vận Hành - IT',
    bio: 'Tôi đảm bảo mọi hoạt động từ khâu tư vấn đến lúc nhận hàng đều đồng bộ, được hoàn thành chính xác, nhanh chóng với trải nghiệm tối ưu nhất cho khách hàng.',
    phone: '+84353839500',
    button: 'Gọi Mr. Vinh'
  }
];

const productCategories = [
  {
    icon: '📦',
    title: 'Văn Phòng Phẩm',
    text: 'Bút, giấy note, kẹp giấy, ghim, bìa hồ sơ, dụng cụ lưu trữ và nhiều sản phẩm văn phòng khác.'
  },
  {
    icon: '📄',
    title: 'Sản Phẩm Về Giấy',
    text: 'Giấy in, giấy A4, giấy bìa, giấy màu, giấy chuyên dụng và các sản phẩm giấy phục vụ vận hành.'
  },
  {
    icon: '🎒',
    title: 'Bách Hóa Văn Phòng',
    text: 'Nhu yếu phẩm văn phòng, sản phẩm vệ sinh, vật tư tiêu hao và các mặt hàng hỗ trợ môi trường làm việc.'
  }
];

const b2bValues = [
  {
    number: '01',
    title: 'Báo giá rõ ràng',
    text: 'Dễ so sánh, dễ duyệt nội bộ, hạn chế phát sinh ngoài kế hoạch.'
  },
  {
    number: '02',
    title: 'Đặt hàng linh hoạt',
    text: 'Hỗ trợ theo nhu cầu định kỳ, phát sinh hoặc đơn hàng riêng của từng phòng ban.'
  },
  {
    number: '03',
    title: 'Giao nhận có kiểm soát',
    text: 'Quy trình bàn giao rõ ràng, hỗ trợ theo dõi và đối soát thuận tiện.'
  }
];
---

<Layout
  title="Khách Hàng Doanh Nghiệp — Long Hưng"
  description="Phòng kinh doanh Long Hưng - Giải pháp cung ứng văn phòng phẩm cho doanh nghiệp."
>
  <Header currentPage="/khach-hang" />

  <!-- Hero Section -->
  <section
    class="hero hero-page hero-business"
    style="background-image: url('/images/hero-vpp.webp')"
  >
    <div class="hero-inner">
      <div class="page-hero-content">
        <p class="eyebrow">Giải pháp B2B</p>
        <h1>Đồng hành cùng vận hành văn phòng của doanh nghiệp</h1>
        <p>
          Long Hưng hỗ trợ doanh nghiệp mua sắm văn phòng phẩm theo cách minh bạch,
          tối ưu và dễ kiểm soát hơn.
        </p>
      </div>
    </div>
  </section>

  <!-- B2B Values -->
  <section class="b2b-value-section">
    <div class="container">
      <div class="grid grid-3 reveal-stagger">
        {b2bValues.map((item) => (
          <div class="feature-card b2b-value-card" data-number={item.number}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="team-section">
    <div class="container">
      <div class="section-heading text-center" data-reveal>
        <p class="section-subtitle">Phụ trách khách hàng doanh nghiệp</p>
        <h2 class="section-title">Phòng kinh doanh kính chào mừng bạn!</h2>
      </div>

      <div class="grid grid-2 team-grid reveal-stagger">
        {teamMembers.map((member) => (
          <div class="team-card">
            <div class="team-image">
              <img src={member.image} alt={member.name} />
            </div>

            <div class="team-info">
              <h3>{member.name}</h3>
              <p class="team-position">{member.position}</p>
              <p class="team-bio">{member.bio}</p>
              <a href={`tel:${member.phone}`} class="btn btn-secondary mt-3">
                {member.button}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Client Strip -->
  <section class="client-section">
    <div class="container">
      <h2 class="section-title text-center mb-4">Khách Hàng Tiêu Biểu</h2>
      <div class="client-strip">
        <img
          src="/images/client-strip.webp"
          alt="Khách hàng tiêu biểu của Long Hưng"
          class="client-image"
        />
      </div>
    </div>
  </section>

  <!-- Product Categories -->
  <section class="product-section">
    <div class="container">
      <div class="section-heading text-center" data-reveal>
        <p class="section-subtitle">Danh mục cung ứng</p>
        <h2 class="section-title">Danh Mục Sản Phẩm</h2>
      </div>

      <div class="grid grid-3 reveal-stagger">
        {productCategories.map((category) => (
          <div class="product-card">
            <div class="product-icon">{category.icon}</div>
            <h3>{category.title}</h3>
            <p>{category.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact-section">
    <ContactForm
      title="Liên Hệ Phòng Kinh Doanh"
      subtitle="Để tìm hiểu thêm về giải pháp văn phòng phẩm cho doanh nghiệp"
    />
  </section>

  <Footer />
</Layout>