---
// src/pages/ve-chung-toi.astro - Page 5: Về chúng tôi
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Về Chúng Tôi — Văng Phòng Phẩm Long Hưng" description="Về Văng Phòng Phẩm Long Hưng - Câu chuyện, sứ mệnh, và dịch vụ của chúng tôi.">
  <Header currentPage="/ve-chung-toi" />

  <!-- Hero Section -->
  <section class="hero" style="background-image: url('/images/about-bg.jpg')">
    <div class="hero-content">
      <h1>Về Chúng Tôi</h1>
      <p class="hero-subtitle">Sứ Mệnh, Tầm Nhìn & Giá Trị</p>
    </div>
  </section>

  <!-- About Content -->
  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2 class="section-title">Câu Chuyện Long Hưng</h2>
          <p>
            Văng Phòng Phẩm Long Hưng được thành lập với mục đích cung cấp giải pháp văn phòng phẩm toàn diện cho
            doanh nghiệp và người tiêu dùng tại Hà Nội và các vùng lân cận.
          </p>
          <p>
            Chúng tôi tin rằng chất lượng, minh bạch, và phục vụ tận tâm là chìa khóa để xây dựng các mối quan hệ lâu dài
            với khách hàng.
          </p>
          <p>
            Hôm nay, Long Hưng đã trở thành một trong những nhà cung cấp văn phòng phẩm đáng tin cậy tại thành phố.
          </p>
        </div>
        <div class="about-stats">
          <div class="stat-card">
            <div class="stat-number">500+</div>
            <div class="stat-label">Khách Hàng</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">10+</div>
            <div class="stat-label">Năm Kinh Nghiệm</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">1000+</div>
            <div class="stat-label">Sản Phẩm</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">24/7</div>
            <div class="stat-label">Hỗ Trợ</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services-section">
    <div class="container">
      <h2 class="section-title text-center mb-4">Dịch Vụ Của Chúng Tôi</h2>
      <div class="grid grid-3">
        <div class="service-card">
          <div class="service-icon">🏢</div>
          <h3>Cung Ứng B2B</h3>
          <p>
            Giải pháp văn phòng phẩm toàn diện cho các doanh nghiệp, công ty, và tổ chức.
          </p>
        </div>
        <div class="service-card">
          <div class="service-icon">🛍️</div>
          <h3>Bán Lẻ</h3>
          <p>
            Nhà sách Long Hưng cung cấp các sản phẩm chất lượng cao cho người tiêu dùng cá nhân.
          </p>
        </div>
        <div class="service-card">
          <div class="service-icon">🚚</div>
          <h3>Giao Hàng</h3>
          <p>
            Vận chuyển an toàn, nhanh chóng đến tận nhà, với giá cạnh tranh.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="values-section">
    <div class="container">
      <h2 class="section-title text-center mb-4">Giá Trị Cốt Lõi</h2>
      <div class="grid grid-3">
        <div class="value-card">
          <h3>Chất Lượng</h3>
          <p>
            Mỗi sản phẩm được lựa chọn và kiểm tra kỹ để đảm bảo chất lượng tốt nhất cho khách hàng.
          </p>
        </div>
        <div class="value-card">
          <h3>Minh Bạch</h3>
          <p>
            Chúng tôi cam kết báo giá rõ ràng, không phụ phí ẩn, và giao dịch công bằng với mọi khách hàng.
          </p>
        </div>
        <div class="value-card">
          <h3>Phục Vụ Tận Tâm</h3>
          <p>
            Đội ngũ chúng tôi luôn sẵn sàng hỗ trợ bạn 24/7 để giải quyết mọi nhu cầu và câu hỏi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact-section">
    <ContactForm title="Liên Hệ Với Chúng Tôi" subtitle="Để biết thêm thông tin về sản phẩm và dịch vụ" />
  </section>

  <Footer />
</Layout>

<style>
  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    font-family: var(--font-script);
    color: var(--color-gold-light);
    margin-bottom: var(--spacing-lg);
  }

  .about-section {
    padding: var(--spacing-2xl) 0;
    background-color: var(--color-bg);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
  }

  .about-text p {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
  }

  .stat-card {
    background-color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  .stat-label {
    color: var(--color-brown);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .services-section {
    padding: var(--spacing-2xl) 0;
  }

  .service-card {
    background: linear-gradient(135deg, rgba(102, 0, 17, 0.05) 0%, rgba(171, 106, 36, 0.05) 100%);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    text-align: center;
    transition: all var(--transition-normal);
  }

  .service-card:hover {
    transform: translateY(-4px);
    background: linear-gradient(135deg, rgba(102, 0, 17, 0.1) 0%, rgba(171, 106, 36, 0.1) 100%);
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
  }

  .service-card h3 {
    color: var(--color-brown);
    margin-bottom: var(--spacing-md);
  }

  .service-card p {
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .values-section {
    background-color: var(--color-bg);
    padding: var(--spacing-2xl) 0;
  }

  .value-card {
    background-color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    border-top: 4px solid var(--color-gold);
  }

  .value-card h3 {
    color: var(--color-brown);
    margin-bottom: var(--spacing-md);
  }

  .value-card p {
    color: var(--color-gray);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .about-stats {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-md);
    }

    .stat-card {
      padding: var(--spacing-md);
    }

    .stat-number {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .about-text p {
      font-size: 0.95rem;
    }
  }
</style>
