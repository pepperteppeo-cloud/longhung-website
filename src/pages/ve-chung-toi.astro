---
// src/pages/ve-chung-toi.astro - Page 5: Về chúng tôi
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const stats = [
  {
    number: '100+',
    label: 'Khách Hàng'
  },
  {
    number: '5+',
    label: 'Năm Kinh Nghiệm'
  },
  {
    number: '300+',
    label: 'Sản Phẩm'
  },
  {
    number: '24/7',
    label: 'Hỗ Trợ'
  }
];

const services = [
  {
    icon: '/images/icon-service-b2b.webp',
    title: 'Cung Ứng B2B',
    text: 'Giải pháp văn phòng phẩm toàn diện cho doanh nghiệp, công ty và tổ chức.'
  },
  {
    icon: '/images/icon-service-retail.webp',
    title: 'Bán Lẻ',
    text: 'Nhà sách Long Hưng cung cấp sản phẩm chất lượng cho khách hàng cá nhân và gia đình.'
  },
  {
    icon: '/images/icon-service-delivery.webp',
    title: 'Giao Hàng',
    text: 'Vận chuyển an toàn, linh hoạt và phù hợp với nhu cầu sử dụng thực tế.'
  }
];

const values = [
  {
    title: 'Chất Lượng',
    text: 'Mỗi sản phẩm được lựa chọn và kiểm tra kỹ để đảm bảo trải nghiệm sử dụng ổn định.'
  },
  {
    title: 'Minh Bạch',
    text: 'Báo giá rõ ràng, quy trình đơn giản và giao dịch công bằng với mọi khách hàng.'
  },
  {
    title: 'Phục Vụ Tận Tâm',
    text: 'Đội ngũ Long Hưng luôn sẵn sàng hỗ trợ, lắng nghe và xử lý nhu cầu của khách hàng.'
  }
];
---

<Layout
  title="Về Chúng Tôi — Văn Phòng Phẩm Long Hưng"
  description="Về Văn Phòng Phẩm Long Hưng - Câu chuyện, sứ mệnh, giá trị và dịch vụ của chúng tôi."
>
  <Header currentPage="/ve-chung-toi" />

  <!-- Hero Section -->
  <section
    class="hero hero-page hero-about"
    style="background-image: url('/images/hero-vpp.webp')"
  >
    <div class="hero-inner">
      <div class="page-hero-content">
        <p class="eyebrow">Về Long Hưng</p>
        <h1>Một đối tác văn phòng phẩm đáng tin cậy</h1>
        <p class="page-hero-description">
          Long Hưng được xây dựng từ tình yêu thương và sự tận tâm, cam kết mang đến những sản phẩm chất lượng và dịch vụ tốt nhất cho khách hàng.
        </p>
      </div>
    </div>
  </section>

  <!-- About Content -->
  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text" data-reveal>
          <p class="section-subtitle">Câu chuyện Long Hưng</p>
          <h2 class="section-title">Nơi yêu thương là khởi nguồn, và tận tâm là lời cam kết</h2>

          <p>
           Xuất phát từ tình yêu vô bờ của những bậc cha mẹ dành cho con mình.
           Long Hưng - một hiệu sách nhỏ đã ra đời và trưởng thành từ đó.
          </p>

          <p>
            Trên hành trình đó, chúng tôi tin rằng bốn giá trị cốt lõi chính là nền tảng để xây dựng mối quan hệ bền vững nhất:
          </p>

          <ul class="core-values-list">
            <li><strong>Nhanh chóng</strong> — Đúng hạn, linh hoạt, không để khách hàng chờ đợi.</li>
            <li><strong>Chất lượng</strong> — Sản phẩm chọn lọc, đảm bảo trải nghiệm ổn định lâu dài.</li>
            <li><strong>Tận tâm</strong> — Lắng nghe, thấu hiểu và đồng hành cùng từng khách hàng.</li>
            <li><strong>Chuyên nghiệp</strong> — Quy trình rõ ràng, đội ngũ có kinh nghiệm, làm việc đúng cam kết.</li>
          </ul>

          <p>
          Để đến hôm nay, những con người và "người con" của Long Hưng đã
          không ngừng phát triển. Chuyên nghiệp hơn, tối ưu hơn và gần gũi hơn với từng khách hàng của mình.
          </p>

        </div>

        <div class="about-stats reveal-stagger">
          {stats.map((stat) => (
            <div class="stat-card">
              <div class="stat-number">{stat.number}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Client Strip -->
  <section class="client-section">
    <div class="container">
      <h2 class="section-title text-center mb-4">Khách Hàng Tiêu Biểu</h2>
      <div class="client-strip">
        <img
          src="/images/client-strip.webp"
          alt="Khách hàng tiêu biểu của Long Hưng"
          class="client-image"
        />
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services-section">
    <div class="container">
      <div class="section-heading text-center" data-reveal>
        <p class="section-subtitle">Dịch vụ</p>
        <h2 class="section-title">Dịch Vụ Của Chúng Tôi</h2>
      </div>

      <div class="grid grid-3 reveal-stagger">
        {services.map((service) => (
          <div class="service-card service-card--illustrated">
            <img
              src={service.icon}
              alt=""
              class="card-bg-photo"
              style="position:absolute;inset:0;width:100%;height:100%;max-width:none;object-fit:cover;object-position:center;transform:scale(1.08);opacity:0.9;pointer-events:none;z-index:0;"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <div class="card-copy" style="position:relative;z-index:1;">
              <h3>{service.title}</h3>
              <p>{service.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="values-section">
    <div class="container">
      <div class="section-heading text-center" data-reveal>
        <p class="section-subtitle">Giá trị</p>
        <h2 class="section-title">Giá Trị Cốt Lõi</h2>
      </div>

      <div class="grid grid-3 reveal-stagger">
        {values.map((value) => (
          <div class="value-card">
            <h3>{value.title}</h3>
            <p>{value.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact-section">
    <ContactForm
      title="Liên Hệ Với Chúng Tôi"
      subtitle="Để biết thêm thông tin về sản phẩm và dịch vụ"
    />
  </section>

  <Footer />
</Layout>