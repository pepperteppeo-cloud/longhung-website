---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const policyGroups = [
  {
    title: 'Chính sách chung',
    items: [
      { title: 'Bảo mật thông tin cá nhân', href: '/chinh-sach/bao-mat-thong-tin-ca-nhan' },
      { title: 'Thanh toán', href: '/chinh-sach/thanh-toan' },
      { title: 'Vận chuyển và giao nhận', href: '/chinh-sach/van-chuyen-giao-nhan' },
      { title: 'Đổi trả và hoàn tiền', href: '/chinh-sach/doi-tra-hoan-tien' },
      { title: 'Bảo hành', href: '/chinh-sach/bao-hanh' },
      { title: 'Điều khoản giao dịch', href: '/dieu-khoan-giao-dich' }
    ]
  },
  {
    title: 'Hỗ trợ khách hàng',
    items: [
      { title: 'Quy trình tiếp nhận khiếu nại', href: '/ho-tro/khieu-nai' }
    ]
  },
  {
    title: 'Khách hàng doanh nghiệp',
    items: [
      { title: 'Chính sách bán hàng doanh nghiệp', href: '/khach-hang-doanh-nghiep/chinh-sach-ban-hang' },
      { title: 'Chính sách công nợ doanh nghiệp', href: '/khach-hang-doanh-nghiep/chinh-sach-cong-no' },
      { title: 'Quy trình đặt hàng doanh nghiệp', href: '/khach-hang-doanh-nghiep/quy-trinh-dat-hang' }
    ]
  }
];
---

<Layout
  title="Chính sách Long Hưng — Tổng hợp chính sách và điều khoản"
  description="Tổng hợp chính sách bảo mật, thanh toán, vận chuyển, bảo hành, đổi trả và điều khoản giao dịch của Long Hưng."
>
  <Header currentPage="/chinh-sach" />

  <main class="policy-hub-page">
    <section class="hero hero-page hero-policy-hub" style="background-image: url('/images/about-bg.webp')">
      <div class="hero-inner hero-inner--policy-hub">
        <div class="page-hero-content page-hero-content--policy-hub">
          <p class="hero-kicker">Trung tâm thông tin chính thức</p>
          <h1 class="hero-title">Cẩm nang chính sách, điều khoản, điều kiện và quy trình giao dịch</h1>
          <p class="hero-subtitle">Tổng hợp đầy đủ các quy định và cam kết dịch vụ để bạn tham khảo nhanh trong quá trình giao dịch với Long Hưng.</p>
        </div>
      </div>
    </section>

    <section class="policy-hub-list">
      <div class="container">
        {policyGroups.map((group) => (
          <div class="policy-group">
            <h2>{group.title}</h2>
            <ul>
              {group.items.map((item) => (
                <li>
                  <a href={item.href}>{item.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .policy-hub-page {
    background-color: var(--color-white);
  }

  .hero-policy-hub {
    --hero-position: center 44%;
    min-height: 520px;
    height: min(60vh, 700px);
  }

  .hero-policy-hub::before {
    background:
      radial-gradient(
        circle at 12% 34%,
        rgba(0, 0, 0, 0.3) 0%,
        rgba(0, 0, 0, 0) 54%
      ),
      linear-gradient(
        95deg,
        rgba(0, 0, 0, 0.44) 0%,
        rgba(0, 0, 0, 0.28) 36%,
        rgba(0, 0, 0, 0.12) 74%,
        rgba(0, 0, 0, 0.05) 100%
      );
  }

  .hero-inner--policy-hub {
    align-items: center;
    justify-content: flex-start;
  }

  .page-hero-content--policy-hub {
    max-width: 760px;
    padding: clamp(1rem, 2vw, 1.35rem) clamp(1rem, 2.2vw, 1.6rem);
    border-radius: 22px;
    background: linear-gradient(
      155deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0.08) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.24);
    backdrop-filter: blur(8px) saturate(115%);
    -webkit-backdrop-filter: blur(8px) saturate(115%);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.16);
  }

  .hero-policy-hub .hero-kicker {
    display: inline-flex;
    align-items: center;
    margin: 0 0 0.75rem;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(245, 232, 198, 0.2);
    border: 1px solid rgba(245, 232, 198, 0.42);
    color: rgba(255, 244, 221, 0.96);
    font-family: var(--font-display);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }

  .hero-policy-hub .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.6vw, 3.8rem);
    line-height: 1.12;
    letter-spacing: 0.2px;
    color: var(--color-gold-light);
    text-shadow:
      0 4px 18px rgba(0, 0, 0, 0.4),
      0 1px 3px rgba(0, 0, 0, 0.32);
    margin: 0 0 0.75rem;
  }

  .hero-policy-hub .hero-subtitle {
    margin: 0;
    max-width: 62ch;
    color: rgba(255, 248, 233, 0.94);
    font-size: clamp(0.98rem, 1.2vw, 1.12rem);
    line-height: 1.55;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  .policy-hub-list {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
  }

  .policy-group {
    margin-bottom: var(--spacing-2xl);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-lg);
    background: #fff;
    padding: var(--spacing-lg);
  }

  .policy-group h2 {
    margin-top: 0;
    margin-bottom: var(--spacing-md);
  }

  .policy-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .policy-group a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .policy-group a:hover {
    color: var(--color-brown);
  }

  @media (max-width: 768px) {
    .hero-policy-hub {
      min-height: 420px;
      height: min(52vh, 520px);
      --hero-position: 58% center;
    }

    .page-hero-content--policy-hub {
      padding: 0.9rem 1rem;
      border-radius: 16px;
    }

    .hero-policy-hub .hero-title {
      font-size: clamp(1.6rem, 6vw, 2.4rem);
      max-width: 19ch;
    }

    .hero-policy-hub .hero-kicker {
      font-size: 0.74rem;
      letter-spacing: 0.6px;
      margin-bottom: 0.6rem;
    }

    .hero-policy-hub .hero-subtitle {
      font-size: 0.95rem;
      line-height: 1.45;
    }
  }
</style>
