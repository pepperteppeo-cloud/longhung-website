---
// src/pages/index.astro - Page 1: VPP B2B Home
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const features = [
  {
    number: '01',
    title: 'Siêu Tốc',
    text: 'Giao hàng nhanh chóng, đúng hạn và phù hợp với nhịp vận hành của doanh nghiệp.'
  },
  {
    number: '02',
    title: 'Minh Bạch',
    text: 'Báo giá rõ ràng, chứng từ đầy đủ, quy trình làm việc dễ kiểm soát.'
  },
  {
    number: '03',
    title: 'Tối Ưu',
    text: 'Tối ưu chi phí mua sắm văn phòng phẩm mà vẫn đảm bảo chất lượng sử dụng.'
  },
  {
    number: '04',
    title: 'An Toàn',
    text: 'Sản phẩm chính hãng, giao dịch rõ ràng và hỗ trợ sau bán tận tâm.'
  }
];

const commitments = [
  {
    number: '01',
    title: 'Nhanh Chóng',
    text: 'Xử lý đơn hàng trong 24 giờ, hỗ trợ giao hàng linh hoạt theo nhu cầu.'
  },
  {
    number: '02',
    title: 'Chất Lượng',
    text: 'Hàng hóa được chọn lọc và kiểm tra kỹ trước khi bàn giao.'
  },
  {
    number: '03',
    title: 'Tận Tâm',
    text: 'Tư vấn miễn phí, hỗ trợ khách hàng trong quá trình đặt hàng và sử dụng.'
  },
  {
    number: '04',
    title: 'Chuyên Nghiệp',
    text: 'Đội ngũ có kinh nghiệm, quy trình rõ ràng, làm việc đúng cam kết.'
  }
];

const mapEmbedSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4457.595646593065!2d105.7779734!3d20.9857244!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x313453a56e4f1e1b%3A0xc8a647e05f3fabd7!2zSGnhu4d1IHPDoWNoIExvbmcgSMawbmc!5e1!3m2!1svi!2s!4v1780030444520!5m2!1svi!2s";
---

<Layout
  title="Văn Phòng Phẩm Long Hưng — Cung ứng VPP B2B"
  description="Cung ứng văn phòng phẩm chuyên nghiệp, minh bạch, tối ưu, an toàn cho doanh nghiệp."
>
  <Header currentPage="/" />

  <!-- Hero Section -->
  <section class="hero hero-home" style="background-image: url('/images/hero-vpp.webp')">
    <div class="hero-inner hero-inner--home">
      <div class="brand-slogan hero-layer">
        <h1>
          Open the Door<br />
          Open the Books<br />
          Open the Mind<br />
          Open the Heart
        </h1>
      </div>
    </div>
  </section>

  <!-- Feature Strip -->
  <section class="feature-strip reveal" data-reveal>
    <div class="container">
      <div class="grid grid-4 reveal-stagger">
        {features.map((feature) => (
          <div class="feature-item" data-number={feature.number}>
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commitment Section -->
  <section class="commitment-section reveal" data-reveal>
    <div class="container">
      <div class="commitment-header text-center">
        <p class="section-subtitle">Cam kết và Giải Pháp</p>
        <h2 class="section-title">Nhanh — Gọn — Đúng — Trúng</h2>
        <p class="commitment-text">
          Chúng tôi cung cấp giải pháp văn phòng phẩm toàn diện cho doanh nghiệp:
          từ tư vấn, lựa chọn hàng, báo giá, giao hàng đến hỗ trợ sau bán.
        </p>
      </div>
    </div>
  </section>

  <!-- Four Numbered Cards -->
  <section class="commitment-grid">
    <div class="container">
      <div class="grid grid-4 reveal-stagger">
        {commitments.map((item) => (
          <div class="feature-card" data-number={item.number}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Client Strip -->
  <section class="client-section reveal" data-reveal>
    <div class="container">
      <h2 class="section-title text-center mb-4">Khách Hàng Tiêu Biểu</h2>
      <div class="client-strip">
        <img src="/images/client-strip.webp" alt="Khách hàng tiêu biểu của Long Hưng" class="client-image" />
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact-section" class="reveal" data-reveal>
    <ContactForm title="Tư vấn Ngay" subtitle="Liên hệ với chúng tôi để nhận tư vấn miễn phí" />
  </section>

  <!-- Map Section -->
  <section class="map-section reveal" data-reveal>
    <div class="map-container">
      <iframe
        src={mapEmbedSrc}
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Bản đồ Nhà sách Long Hưng"
      ></iframe>
    </div>
  </section>

  <Footer />
</Layout>