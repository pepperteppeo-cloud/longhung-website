---
// src/pages/index.astro - Page 1: VPP B2B Home
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Văng Phòng Phẩm Long Hưng — Cung ứng VPP B2B" description="Cung ứng văn phòng phẩm chuyên nghiệp, minh bạch, tối ưu, an toàn cho doanh nghiệp.">
  <Header currentPage="/" />

  <!-- Hero Section -->
  <section class="hero" style="background-image: url('/images/hero-vpp.png')">
    <div class="hero-content">
      <h1>Cung ứng Văn Phòng Phẩm</h1>
      <p class="hero-subtitle">Chuyên Nghiệp • Minh Bạch • Tối Ưu • An Toàn</p>
      <a href="#contact-section" class="btn mt-3">Tư vấn Ngay</a>
    </div>
  </section>

  <!-- Feature Strip -->
  <section class="feature-strip">
    <div class="container">
      <div class="grid grid-4">
        <div class="feature-item">
          <div class="feature-icon">⚡</div>
          <h3>Siêu Tốc</h3>
          <p>Giao hàng nhanh chóng, đúng hạn</p>
        </div>
        <div class="feature-item">
          <div class="feature-icon">📋</div>
          <h3>Minh Bạch</h3>
          <p>Báo giá rõ ràng, không phụ phí</p>
        </div>
        <div class="feature-item">
          <div class="feature-icon">💰</div>
          <h3>Tối Ưu</h3>
          <p>Giá tốt nhất, dịch vụ tốt nhất</p>
        </div>
        <div class="feature-item">
          <div class="feature-icon">🛡️</div>
          <h3>An Toàn</h3>
          <p>Hàng chính hãng, bảo hành đầy đủ</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Commitment Section -->
  <section class="commitment-section">
    <div class="container">
      <div class="commitment-header text-center">
        <h2 class="section-subtitle">Cam kết và Giải Pháp</h2>
        <h2 class="section-title">Nhanh — Gọn — Đúng — Trúng</h2>
        <p class="commitment-text">
          Chúng tôi cam kết cung cấp giải pháp văn phòng phẩm toàn diện cho doanh
          nghiệp của bạn, từ tư vấn, lựa chọn hàng, đến giao hàng và hỗ trợ sau bán.
        </p>
      </div>
    </div>
  </section>

  <!-- Four Numbered Cards -->
  <section class="commitment-grid">
    <div class="container">
      <div class="grid grid-4">
        <div class="feature-card" data-number="01">
          <h3>Nhanh Chóng</h3>
          <p>Xử lý đơn hàng trong 24 giờ, giao hàng trong 3 ngày</p>
        </div>
        <div class="feature-card" data-number="02">
          <h3>Chất Lượng</h3>
          <p>Hàng hóa chính hãng, kiểm tra kỹ trước khi giao</p>
        </div>
        <div class="feature-card" data-number="03">
          <h3>Tận Tâm</h3>
          <p>Tư vấn miễn phí, hỗ trợ 24/7 cho khách hàng</p>
        </div>
        <div class="feature-card" data-number="04">
          <h3>Chuyên Nghiệp</h3>
          <p>Đội ngũ kinh nghiệm, quy trình hoạt động chuyên chuẩn</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Client Strip -->
  <section class="client-section">
    <div class="container">
      <h2 class="section-title text-center mb-4">Khách Hàng Tiêu Biểu</h2>
      <div class="client-strip">
        <img src="/images/client-strip.png" alt="Khách hàng tiêu biểu" class="client-image" />
      </div>
    </div>
  </section>


  <!-- Contact Section -->
  <section id="contact-section">
    <ContactForm title="Tư vấn Ngay" subtitle="Liên hệ với chúng tôi để nhận tư vấn miễn phí" />
  </section>

  <section class="map-section">
    <div class="map-container">
      <iframe 
  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4457.595646593065!2d105.7779734!3d20.9857244!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x313453a56e4f1e1b%3A0xc8a647e05f3fabd7!2zSGnhu4d1IHPDoWNoIExvbmcgSMawbmc!5e1!3m2!1svi!2s!4v1780030444520!5m2!1svi!2s" 
  width="100%" 
  height="450" 
  style="border:0;" 
  allowfullscreen="" 
  loading="lazy" 
  referrerpolicy="no-referrer-when-downgrade">
</iframe>

    </div>
  <Footer />
</Layout>

<style>
  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    font-family: var(--font-script);
    color: var(--color-gold-light);
    margin-bottom: var(--spacing-lg);
  }

  .feature-strip {
    background-color: var(--color-bg);
    padding: var(--spacing-2xl) 0;
  }

  .feature-item {
    text-align: center;
    padding: var(--spacing-lg);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
  }

  .feature-item h3 {
    color: var(--color-brown);
    margin-bottom: var(--spacing-sm);
  }

  .feature-item p {
    color: var(--color-gray);
    margin: 0;
  }

  .commitment-section {
    background: linear-gradient(135deg, rgba(102, 0, 17, 0.05) 0%, rgba(171, 106, 36, 0.05) 100%);
    padding: var(--spacing-2xl) 0;
  }

  .commitment-header {
    max-width: 600px;
    margin: 0 auto;
  }

  .section-subtitle {
    font-family: var(--font-script);
    color: var(--color-gold);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
  }

  .commitment-text {
    color: var(--color-gray);
    font-size: 1rem;
    line-height: 1.8;
  }

  .commitment-grid {
    padding: var(--spacing-2xl) 0;
  }

  .clients-section {
    background-color: var(--color-white);
    padding: var(--spacing-2xl) 0;
    border-top: 1px solid var(--color-gray-light);
  }

  .clients-strip {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    min-height: 200px;
  }

  .clients-image {
    max-width: 100%;
    height: auto;
    max-height: 150px;
  }

  @media (max-width: 768px) {
    .hero-subtitle {
      font-size: 1.25rem;
    }

    .clients-strip {
      padding: var(--spacing-xl);
      min-height: 150px;
    }
  }
</style>
