---
// src/pages/index.astro - Page 1: VPP B2B Home
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:5000';
let featuredArticles = [];

try {
  const response = await fetch(`${API_URL}/api/articles?limit=3`);
  const data = await response.json();
  featuredArticles = data?.success && Array.isArray(data.data) ? data.data.slice(0, 3) : [];
} catch {
  featuredArticles = [];
}

const businessBranches = [
  {
    id: 'retail',
    title: 'Nhà Sách Long Hưng',
    subtitle: 'Chuỗi bán lẻ',
    description: 'Phục vụ cư dân các khu đô thị cục bộ với lợi thế ưu tiên về tính tiện lợi, thời gian giao hàng nhanh và độ đầy đủ về mặt hàng hóa.',
    advantages: [
      {
        icon: '📍',
        title: 'Tiện Lợi',
        text: 'Các điểm bán lẻ gần gũi, dễ tiếp cận từ khu dân cư'
      },
      {
        icon: '⚡',
        title: 'Nhanh Chóng',
        text: 'Giao hàng tận nơi nhanh, phục vụ đúng giờ'
      },
      {
        icon: '📦',
        title: 'Đầy Đủ',
        text: 'Hàng hóa đa dạng, luôn có sẵn để phục vụ nhu cầu'
      }
    ],
    cta: 'Khám Phá Nhà Sách',
    link: '/nha-sach'
  },
  {
    id: 'b2b',
    title: 'Văn Phòng Phẩm Long Hưng',
    subtitle: 'Giải Pháp B2B',
    description: 'Cung ứng cho các doanh nghiệp mua hàng văn phòng phẩm thường xuyên với lợi thế tốc độ, quy trình rõ ràng, xuất xứ đảm bảo và cung ứng ổn định.',
    advantages: [
      {
        icon: '🚀',
        title: 'Tốc Độ',
        text: 'Xử lý đơn hàng nhanh, hỗ trợ giao hàng linh hoạt'
      },
      {
        icon: '✓',
        title: 'Quy Trình Rõ Ràng',
        text: 'Báo giá minh bạch, chứng từ đầy đủ, dễ kiểm soát'
      },
      {
        icon: '🛡️',
        title: 'Đảm Bảo Chất Lượng',
        text: 'Sản phẩm chính hãng, xuất xứ rõ ràng, cung ứng ổn định'
      }
    ],
    cta: 'Tư Vấn Ngay',
    link: '/khach-hang'
  }
];

const commitments = [
  {
    number: '01',
    title: 'Nhanh Chóng',
    text: 'Xử lý đơn hàng trong 24 giờ, hỗ trợ giao hàng linh hoạt theo nhu cầu.'
  },
  {
    number: '02',
    title: 'Chất Lượng',
    text: 'Hàng hóa được chọn lọc và kiểm tra kỹ trước khi bàn giao.'
  },
  {
    number: '03',
    title: 'Tận Tâm',
    text: 'Tư vấn miễn phí, hỗ trợ khách hàng trong quá trình đặt hàng và sử dụng.'
  },
  {
    number: '04',
    title: 'Chuyên Nghiệp',
    text: 'Đội ngũ có kinh nghiệm, quy trình rõ ràng, làm việc đúng cam kết.'
  }
];

const mapEmbedSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4457.595646593065!2d105.7779734!3d20.9857244!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x313453a56e4f1e1b%3A0xc8a647e05f3fabd7!2zSGnhu4d1IHPDoWNoIExvbmcgSMawbmc!5e1!3m2!1svi!2s!4v1780030444520!5m2!1svi!2s";
---

<Layout
  title="Văn Phòng Phẩm Long Hưng — Cung ứng VPP B2B"
  description="Cung ứng văn phòng phẩm chuyên nghiệp, minh bạch, tối ưu, an toàn cho doanh nghiệp."
>
  <Header currentPage="/" />

  <!-- Hero Section -->
  <section class="hero hero-home" style="background-image: url('/images/hero-vpp.webp')">
    <div class="hero-inner hero-inner--home">
      <div class="brand-slogan hero-layer">
        <h1>
          Open the Door<br />
          Open the Books<br />
          Open the Mind<br />
          Open the Heart
        </h1>
      </div>
    </div>
  </section>

  <!-- Business Branches Section -->
  <section class="branches-section reveal" data-reveal>
    <div class="container">
      <div class="branches-header text-center">
        <p class="section-subtitle">Công ty TNHH Văn phòng phẩm Long Hưng</p>
        <h2 class="section-title">Hai Nhánh Kinh Doanh, Một Tinh Thần Phục Vụ</h2>
      </div>
      <div class="branches-grid">
        {businessBranches.map((branch) => (
          <div class="branch-card" data-branch={branch.id}>
            <div class="branch-card-header">
              <h3 class="branch-title">{branch.title}</h3>
              <p class="branch-subtitle">{branch.subtitle}</p>
            </div>
            <p class="branch-description">{branch.description}</p>
            <div class="branch-advantages">
              {branch.advantages.map((advantage) => (
                <div class="advantage-item">
                  <span class="advantage-icon">{advantage.icon}</span>
                  <div class="advantage-content">
                    <h4>{advantage.title}</h4>
                    <p>{advantage.text}</p>
                  </div>
                </div>
              ))}
            </div>
            <a href={branch.link} class="btn btn-branch">{branch.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commitment Section -->
  <section class="commitment-section reveal" data-reveal>
    <div class="container">
      <div class="commitment-header text-center">
        <p class="section-subtitle">Cam kết và Giải Pháp</p>
        <h2 class="section-title">Nhanh — Gọn — Đúng — Trúng</h2>
        <p class="commitment-text">
          Chúng tôi cung cấp giải pháp văn phòng phẩm toàn diện cho doanh nghiệp:
          từ tư vấn, lựa chọn hàng, báo giá, giao hàng đến hỗ trợ sau bán.
        </p>
      </div>
    </div>
  </section>

  <!-- Four Numbered Cards -->
  <section class="commitment-grid">
    <div class="container">
      <div class="grid grid-4 reveal-stagger">
        {commitments.map((item) => (
          <div class="feature-card" data-number={item.number}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Client Strip -->
  <section class="client-section reveal" data-reveal>
    <div class="container">
      <h2 class="section-title text-center mb-4">Khách Hàng Tiêu Biểu</h2>
      <div class="client-strip">
        <img src="/images/client-strip.webp" alt="Khách hàng tiêu biểu của Long Hưng" class="client-image" />
      </div>
    </div>
  </section>

  <!-- Featured News Section -->
  <section class="news-preview reveal" data-reveal>
    <div class="container">
      <div class="news-preview-header">
        <div>
          <p class="section-subtitle">Tin tức nổi bật</p>
          <h2 class="section-title">Cập nhật nhanh từ Long Hưng</h2>
        </div>
        <a href="/tin-tuc" class="btn btn-outline news-link">Xem tất cả tin tức</a>
      </div>

      {featuredArticles.length > 0 ? (
        <div class="news-grid">
          {featuredArticles.map((article) => (
            <article class="news-card">
              <div class="news-card-body">
                <span class="news-pill">Tin mới</span>
                <h3>{article.title}</h3>
                <p>{article.excerpt || article.content?.slice(0, 120)}</p>
                <a href={`/tin-tuc/${article.slug}`} class="news-read-more">Đọc tiếp →</a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="news-empty">
          <p>Chưa có tin tức mới được đăng. Hãy quay lại sớm nhé.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact-section" class="reveal" data-reveal>
    <ContactForm title="Tư vấn Ngay" subtitle="Liên hệ với chúng tôi để nhận tư vấn miễn phí" />
  </section>

  <!-- Map Section -->
  <section class="map-section reveal" data-reveal>
    <div class="map-container">
      <iframe
        src={mapEmbedSrc}
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Bản đồ Nhà sách Long Hưng"
      ></iframe>
    </div>
  </section>

  <style>
    .news-preview {
      padding: 1rem 0 2rem;
      background: linear-gradient(180deg, #f6efe2 0%, #fffaf3 100%);
    }

    .news-preview-header {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .news-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .news-card {
      border: 1px solid #ead7c1;
      border-radius: 18px;
      background: linear-gradient(180deg, #fff 0%, #fffaf4 100%);
      box-shadow: 0 12px 24px rgba(68, 43, 18, 0.08);
      overflow: hidden;
    }

    .news-card-body {
      padding: 1rem;
    }

    .news-pill {
      display: inline-flex;
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
      background: #7a3d10;
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      margin-bottom: 0.7rem;
    }

    .news-card h3 {
      margin: 0 0 0.5rem;
      font-size: 1.05rem;
      color: #2f2518;
      line-height: 1.35;
    }

    .news-card p {
      margin: 0 0 0.85rem;
      color: #5d4a39;
      line-height: 1.55;
    }

    .news-read-more {
      color: #7a3d10;
      font-weight: 700;
      text-decoration: none;
    }

    .news-empty {
      border: 1px dashed #d8c2a8;
      border-radius: 16px;
      padding: 1rem;
      background: #fff;
    }

    @media (max-width: 1080px) {
      .news-preview-header {
        align-items: start;
        flex-direction: column;
      }
    }

    @media (max-width: 680px) {
      .news-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <Footer />
</Layout>