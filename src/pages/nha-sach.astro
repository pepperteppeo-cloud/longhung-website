---
// src/pages/nha-sach.astro - Page 2: Nhà sách
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const retailFeatures = [
  {
    icon: '/images/retail-feature-quality.webp',
    title: 'Chất Lượng',
    text: 'Đầy đủ hóa đơn chứng từ, nguồn gốc xuất xứ'
  },

  {
    icon: '/images/retail-feature-online.webp',
    title: 'Tiện lợi',
    text: 'Đa dạng phương pháp đặt hàng, nhận hàng'
  },

   {
    icon: '/images/retail-feature-time.webp',
    title: 'Mọi Lúc',
    text: 'Phục vụ linh hoạt mọi khung giờ'
  },

  {
    icon: '/images/retail-feature-delivery.webp',
    title: 'Mọi Nơi',
    text: 'Giao hàng tận nơi, nhanh chóng và chính xác.'
  },

  
];

const commitments = [
  {
    number: '01',
    title: 'Nhanh Chóng',
    text: 'Xử lý đơn hàng trong 24 giờ, hỗ trợ giao hàng linh hoạt theo nhu cầu.'
  },
  {
    number: '02',
    title: 'Chất Lượng',
    text: 'Hàng hóa được chọn lọc và kiểm tra kỹ trước khi bàn giao.'
  },
  {
    number: '03',
    title: 'Tận Tâm',
    text: 'Tư vấn miễn phí, hỗ trợ khách hàng trong quá trình đặt hàng và sử dụng.'
  },
  {
    number: '04',
    title: 'Chuyên Nghiệp',
    text: 'Đội ngũ có kinh nghiệm, quy trình rõ ràng, làm việc đúng cam kết.'
  }
];

const nationwideOrderUrl = 'https://vpplonghung.mshopkeeper.vn/order-page/';
---

<Layout
  title="Nhà Sách Long Hưng — Mua Hàng Giao Hàng Tận Nơi"
  description="Nhà sách bán lẻ Long Hưng - Mua hàng online, giao hàng tận nơi, phục vụ linh hoạt và tận tâm."
>
  <Header currentPage="/nha-sach" />

  <!-- Hero Section -->
  <section
    class="hero hero-page hero-bookstore"
    style="background-image: url('/images/hero-nhasach.webp')"
  >
    <div class="hero-inner">
      <div class="page-hero-content">
        <p class="eyebrow">Nhà sách Long Hưng</p>
        <h1>Mua sắm dễ dàng, mọi lúc mọi nơi</h1>
        <p1 class="page-hero-description">
          Chuỗi cửa hàng Long Hưng – Đáp ứng mọi nhu cầu của cư dân đô thị với dịch vụ giao hàng tận cửa chỉ trong 15 phút!
          
        </p1>

        <div class="hero-cta-row">
          <a href={nationwideOrderUrl} class="btn btn-cta hero-order-cta">Đặt hàng toàn quốc</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Strip -->
  <section class="feature-strip">
    <div class="container">
      <div class="grid grid-4 reveal-stagger">
        {retailFeatures.map((feature) => (
          <div class="feature-item retail-feature retail-feature--illustrated" style="--hide-before:1;">
            <img
              src={feature.icon}
              alt=""
              class="card-bg-photo"
              style="position:absolute;inset:0;width:100%;height:100%;max-width:none;object-fit:cover;object-position:center;transform:scale(1.08);opacity:0.9;pointer-events:none;z-index:0;"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <div class="card-copy" style="position:relative;z-index:1;">
              <h3>{feature.title}</h3>
              <p>{feature.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commitment Section -->
  <section class="commitment-section">
    <div class="container">
      <div class="commitment-header text-center" data-reveal>
        <p class="section-subtitle">Cam kết và Giải Pháp</p>
        <h2 class="section-title">Nhanh — Gọn — Đúng — Trúng</h2>
        <p class="commitment-text">
          Chúng tôi hướng tới trải nghiệm mua sắm gần gũi, rõ ràng và thuận tiện:
          từ chọn hàng, xác nhận đơn, giao hàng đến hỗ trợ sau mua.
        </p>
      </div>
    </div>
  </section>

  <!-- Four Numbered Cards -->
  <section class="commitment-grid">
    <div class="container">
      <div class="grid grid-4 reveal-stagger">
        {commitments.map((item) => (
          <div class="feature-card" data-number={item.number}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Clients Strip -->
  <section class="client-section">
    <div class="container">
      <h2 class="section-title text-center mb-4">Khách Hàng Tiêu Biểu</h2>
      <div class="client-strip">
        <img
          src="/images/client-strip.webp"
          alt="Khách hàng tiêu biểu của Long Hưng"
          class="client-image"
        />
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact-section">
    <ContactForm
      title="Đặt Hàng Ngay"
      subtitle="Liên hệ để đặt hàng hoặc tư vấn về sản phẩm phù hợp"
    />
  </section>

  <Footer />
</Layout>

<style>
  .hero-cta-row {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-order-cta {
    background-color: var(--color-light-brown);
    color: var(--color-brown);
  }

  .hero-order-cta:hover {
    background-color: #e2c991;
    color: var(--color-brown);
  }
</style>