import PolicyPage from '../../components/PolicyPage.astro';

const tocLinks = [
  { title: 'Phạm vi áp dụng', href: '#pham-vi-ap-dung' },
  { title: 'Sản phẩm thuộc diện bảo hành', href: '#san-pham-thuoc-dien-bao-hanh' },
  { title: 'Điều kiện được xem xét bảo hành', href: '#dieu-kien-duoc-xem-xet-bao-hanh' },
  { title: 'Trường hợp không thuộc phạm vi bảo hành', href: '#truong-hop-khong-thuoc-pham-vi-bao-hanh' },
  { title: 'Quy trình tiếp nhận bảo hành', href: '#quy-trinh-tiep-nhan-bao-hanh' },
