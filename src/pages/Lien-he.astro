---
// src/pages/lien-he.astro
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Liên hệ | VPP Long Hưng">
  <div class="container page-wrapper">
    <div class="contact-info">
      <h1>Liên hệ với chúng tôi</h1>
      <p>Hãy để lại thông tin, đội ngũ VPP Long Hưng sẽ liên hệ lại với bạn trong thời gian sớm nhất.</p>
      
      <div class="info-details">
        <p><strong>Email:</strong> kinhdoanh@vpplonghung.com</p>
        <p><strong>Giờ làm việc:</strong> Thứ 2 - Thứ 7 (8:00 - 17:30)</p>
      </div>
    </div>

    <div class="form-wrapper">
      <!-- Gọi form liên hệ vào đây -->
      <ContactForm />
    </div>
  </div>
</Layout>

<style>
  .page-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 4rem 1.5rem;
  }
  .contact-info h1 {
    margin-bottom: 1rem;
  }
  .info-details {
    margin-top: 2rem;
    background-color: var(--color-light-bg);
    padding: 1.5rem;
    border-radius: 8px;
  }
  
  @media (max-width: 768px) {
    .page-wrapper {
      grid-template-columns: 1fr;
    }
  }
</style>