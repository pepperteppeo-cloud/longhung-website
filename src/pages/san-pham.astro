---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { productCategories, products, priceRange, formatPriceVnd } from '../data/products';

const productCount = products.length;
const minPrice = Number.isFinite(priceRange.min) ? priceRange.min : 0;
const maxPrice = Number.isFinite(priceRange.max) ? priceRange.max : 0;

const queryParams = Astro.url.searchParams;
const initialKeyword = queryParams.get('q')?.trim() ?? '';
const initialCategory = queryParams.get('category')?.trim() ?? '';
const initialMinPrice = queryParams.get('minPrice')?.trim() ?? '';
const initialMaxPrice = queryParams.get('maxPrice')?.trim() ?? '';

const initialMinPriceValue = Number.parseInt(initialMinPrice, 10);
const initialMaxPriceValue = Number.parseInt(initialMaxPrice, 10);

const hasInitialMinPrice = Number.isFinite(initialMinPriceValue);
const hasInitialMaxPrice = Number.isFinite(initialMaxPriceValue);

const hasInitialFilters = Boolean(
  initialKeyword || initialCategory || hasInitialMinPrice || hasInitialMaxPrice
);

const normalizeVietnameseServer = (value: string): string => {
  return (value || '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/đ/g, 'd')
    .replace(/Đ/g, 'd')
    .toLowerCase()
    .trim();
};

const initialNormalizedKeyword = normalizeVietnameseServer(initialKeyword);
const initialKeywordTokens = initialNormalizedKeyword
  ? initialNormalizedKeyword.split(/\s+/).filter(Boolean)
  : [];

const initialVisibleProductIds = new Set(
  products
    .filter((product) => {
      const normalizedName = normalizeVietnameseServer(product.name);
      const keywordMatch =
        !initialKeywordTokens.length ||
        initialKeywordTokens.every((token) => normalizedName.includes(token));

      const categoryMatch = !initialCategory || initialCategory === product.categoryId;
      const minPriceMatch = !hasInitialMinPrice || product.unitPriceVnd >= initialMinPriceValue;
      const maxPriceMatch = !hasInitialMaxPrice || product.unitPriceVnd <= initialMaxPriceValue;

      return keywordMatch && categoryMatch && minPriceMatch && maxPriceMatch;
    })
    .map((product) => product.stt)
);

const initialVisibleCount = hasInitialFilters
  ? initialVisibleProductIds.size
  : productCount;
---

<Layout title="Sản phẩm | Long Hưng" description="Danh mục sản phẩm đầy đủ của Long Hưng với bộ lọc theo danh mục, khoảng giá và từ khóa.">
  <Header currentPage="/san-pham" />

  <section class="catalog-hero">
    <div class="container hero-inner">
      <p class="hero-kicker">Product <br /> &nbsp&nbspCatalogue <br /> </p>

      <h1><br /> Danh mục sản phẩm</h1>

      <div class="hero-badges">
        {productCategories.map((category) => (
          <span class="hero-badge">{category.name}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="catalog-shell">
    <div class="container">
      <div class="filter-panel">
        <form id="product-filter-form" class="filter-grid" autocomplete="off">
          <label class="filter-field" for="filter-keyword">
            <span class="filter-label">Từ khóa</span>
            <input id="filter-keyword" name="q" type="search" placeholder="Ví dụ: bút bi, giấy A4..." value={initialKeyword} />
          </label>

          <label class="filter-field" for="filter-category">
            <span class="filter-label">Danh mục</span>
            <select id="filter-category" name="category">
              <option value="">Tất cả danh mục</option>
              {productCategories.map((category) => (
                <option value={category.id} selected={initialCategory === category.id}>{category.name}</option>
              ))}
            </select>
          </label>

          <label class="filter-field" for="filter-min-price">
            <span class="filter-label">Giá thấp nhất (VND)</span>
            <input id="filter-min-price" name="minPrice" type="number" min={minPrice} step="500" placeholder={`${minPrice}`} value={initialMinPrice} />
          </label>

          <label class="filter-field" for="filter-max-price">
            <span class="filter-label">Giá cao nhất (VND)</span>
            <input id="filter-max-price" name="maxPrice" type="number" min={minPrice} step="500" placeholder={`${maxPrice}`} value={initialMaxPrice} />
          </label>

          <div class="filter-actions">
            <button type="submit" class="btn btn-filter">Lọc sản phẩm</button>
            <button type="button" id="reset-filters" class="btn btn-outline">Xóa bộ lọc</button>
          </div>
        </form>

        <div class="quick-range" aria-label="Bộ lọc giá nhanh">
          <button type="button" class="chip" data-price-range="all">Tất cả mức giá</button>
          <button type="button" class="chip" data-price-range="budget">Dưới 10.000đ</button>
          <button type="button" class="chip" data-price-range="mid">10.000đ - 50.000đ</button>
          <button type="button" class="chip" data-price-range="premium">Trên 50.000đ</button>
        </div>
      </div>

      <div class="catalog-stats">
        <p id="filter-summary"><strong>{initialVisibleCount}</strong> sản phẩm đang hiển thị</p>
      </div>

      <div class="product-grid" id="product-grid">
        {products.map((product) => (
          (() => {
            const isInitiallyVisible = !hasInitialFilters || initialVisibleProductIds.has(product.stt);

            return (
          <article
            class="product-card"
            data-name={product.name}
            data-category-id={product.categoryId}
            data-category={product.category}
            data-price={product.unitPriceVnd}
            hidden={!isInitiallyVisible}
            style={!isInitiallyVisible ? 'display: none !important;' : undefined}
          >
            <a class="product-thumb" href={`/san-pham/${product.slug}`} aria-label={`Xem sản phẩm ${product.name}`}>
              <img src={product.image} alt={product.name} loading="lazy" />
              <span class="thumb-code" style={`--code-accent: ${product.accentColor}`}>{product.shortCode}</span>
            </a>

            <div class="product-meta">
              <span class="category-tag">{product.category}</span>
              <h2>
                <a href={`/san-pham/${product.slug}`}>{product.name}</a>
              </h2>
              <dl class="price-meta">
                <div>
                  <dt>Đơn vị</dt>
                  <dd>{product.unit}</dd>
                </div>
                <div>
                  <dt>Giá</dt>
                  <dd>{formatPriceVnd(product.unitPriceVnd)}</dd>
                </div>
                <div>
                  <dt>VAT</dt>
                  <dd>{product.vatPercent}%</dd>
                </div>
              </dl>
              <a href={`/san-pham/${product.slug}`} class="btn btn-card">Xem trang sản phẩm</a>
            </div>
          </article>
            );
          })()
        ))}
      </div>

      <div class="empty-state" id="empty-state" hidden={initialVisibleCount > 0}>
        <h3>Không tìm thấy sản phẩm phù hợp</h3>
        <p>Hãy thử đổi từ khóa, nới khoảng giá hoặc chọn danh mục khác.</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const normalizeVietnamese = (value) => {
    return (value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/đ/g, 'd')
      .replace(/Đ/g, 'd')
      .toLowerCase()
      .trim();
  };

  const toInt = (value) => {
    const parsed = Number.parseInt(value, 10);
    return Number.isFinite(parsed) ? parsed : null;
  };

  const tokenize = (value) => {
    const normalized = normalizeVietnamese(value);
    return normalized ? normalized.split(/\s+/).filter(Boolean) : [];
  };

  const initProductFilters = () => {
    const form = document.getElementById('product-filter-form');
    const keywordInput = document.getElementById('filter-keyword');
    const categoryInput = document.getElementById('filter-category');
    const minPriceInput = document.getElementById('filter-min-price');
    const maxPriceInput = document.getElementById('filter-max-price');
    const resetButton = document.getElementById('reset-filters');
    const summary = document.getElementById('filter-summary');
    const emptyState = document.getElementById('empty-state');
    const chips = Array.from(document.querySelectorAll('.chip'));
    const allCards = Array.from(document.querySelectorAll('.product-card'));

    if (!form || !keywordInput || !categoryInput || !minPriceInput || !maxPriceInput || !summary || !emptyState) {
      return;
    }

    const setActiveChip = (chipName) => {
      chips.forEach((chip) => {
        chip.classList.toggle('active', chip.dataset.priceRange === chipName);
      });
    };

    const syncUrl = () => {
      const params = new URLSearchParams();

      const keyword = keywordInput.value.trim();
      const category = categoryInput.value.trim();
      const minPrice = minPriceInput.value.trim();
      const maxPrice = maxPriceInput.value.trim();

      if (keyword) params.set('q', keyword);
      if (category) params.set('category', category);
      if (minPrice) params.set('minPrice', minPrice);
      if (maxPrice) params.set('maxPrice', maxPrice);

      const query = params.toString();
      const nextUrl = query ? `/san-pham?${query}` : '/san-pham';
      window.history.replaceState({}, '', nextUrl);
    };

    const applyFilters = () => {
      const keywordTokens = tokenize(keywordInput.value);
      const category = categoryInput.value;
      const minPrice = toInt(minPriceInput.value);
      const maxPrice = toInt(maxPriceInput.value);

      let visibleCount = 0;

      allCards.forEach((card) => {
        const name = normalizeVietnamese(card.dataset.name || '');
        const cardCategory = card.dataset.categoryId || '';
        const cardPrice = toInt(card.dataset.price || '') || 0;

        const keywordMatch =
          !keywordTokens.length ||
          keywordTokens.every((token) => name.includes(token));
        const categoryMatch = !category || category === cardCategory;
        const minMatch = minPrice === null || cardPrice >= minPrice;
        const maxMatch = maxPrice === null || cardPrice <= maxPrice;
        const isMatch = keywordMatch && categoryMatch && minMatch && maxMatch;

        if (isMatch) {
          card.hidden = false;
          card.style.removeProperty('display');
        } else {
          card.hidden = true;
          card.style.setProperty('display', 'none', 'important');
        }

        if (isMatch) {
          visibleCount += 1;
        }
      });

      summary.innerHTML = `<strong>${visibleCount}</strong> sản phẩm đang hiển thị`;
      emptyState.hidden = visibleCount > 0;
      syncUrl();
    };

    const hydrateFromQuery = () => {
      const params = new URLSearchParams(window.location.search);

      keywordInput.value = params.get('q') || '';
      categoryInput.value = params.get('category') || '';
      minPriceInput.value = params.get('minPrice') || '';
      maxPriceInput.value = params.get('maxPrice') || '';

      setActiveChip('all');
      applyFilters();
    };

    if (form.dataset.filtersBound !== 'true') {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        setActiveChip('all');
        applyFilters();
      });

      [keywordInput, minPriceInput, maxPriceInput].forEach((field) => {
        field.addEventListener('input', () => {
          setActiveChip('all');
          applyFilters();
        });
      });

      categoryInput.addEventListener('change', () => {
        setActiveChip('all');
        applyFilters();
      });

      resetButton?.addEventListener('click', () => {
        keywordInput.value = '';
        categoryInput.value = '';
        minPriceInput.value = '';
        maxPriceInput.value = '';
        setActiveChip('all');
        applyFilters();
      });

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const key = chip.dataset.priceRange || 'all';

          if (key === 'budget') {
            minPriceInput.value = '';
            maxPriceInput.value = '10000';
          } else if (key === 'mid') {
            minPriceInput.value = '10000';
            maxPriceInput.value = '50000';
          } else if (key === 'premium') {
            minPriceInput.value = '50001';
            maxPriceInput.value = '';
          } else {
            minPriceInput.value = '';
            maxPriceInput.value = '';
          }

          setActiveChip(key);
          applyFilters();
        });
      });

      form.dataset.filtersBound = 'true';
    }

    hydrateFromQuery();
  };

  if (!window.__lhProductSearchSyncBound) {
    window.addEventListener('longhung:product-search', () => {
      initProductFilters();
    });
    window.__lhProductSearchSyncBound = true;
  }

  initProductFilters();
  document.addEventListener('astro:page-load', initProductFilters);
  document.addEventListener('astro:after-swap', initProductFilters);
  window.addEventListener('popstate', initProductFilters);
</script>

<style>
  .catalog-hero {
    position: relative;
    background:
      radial-gradient(circle at 12% 20%, rgba(255, 212, 140, 0.4), transparent 44%),
      radial-gradient(circle at 88% 24%, rgba(107, 177, 220, 0.35), transparent 48%),
      linear-gradient(120deg, #201014 0%, #4b1f12 48%, #17334a 100%);
    color: #fff;
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 760px;
  }

  .hero-kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 212, 140, 0.85);
    font-size: 0.9rem;
  }

  .catalog-hero h1 {
    margin-bottom: 1rem;
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 5vw, 3.2rem);
    line-height: 1.15;
    font-weight: 700;
  }

  .hero-description {
    margin: 0;
    max-width: 55ch;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.6;
  }

  .hero-badges {
    display: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.78rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.12);
    font-size: 0.88rem;
  }

  .catalog-shell {
    padding: 2.25rem 0 3.5rem;
    background: linear-gradient(180deg, #f6f2e8 0%, #fbf7ef 100%);
  }

  .filter-panel {
    border-radius: 20px;
    border: 1px solid #eadcc8;
    background: #fffdfa;
    box-shadow: 0 14px 34px rgba(84, 55, 23, 0.1);
    padding: 1.25rem;
    margin-bottom: 1.3rem;
  }

  .filter-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    align-items: end;
  }

  .filter-field {
    display: flex;
    flex-direction: column;
    gap: 0.38rem;
  }

  .filter-label {
    font-size: 0.86rem;
    font-weight: 700;
    color: #5a3116;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .filter-field input,
  .filter-field select {
    min-height: 44px;
    border: 1px solid #d8c6b0;
    border-radius: 10px;
    padding: 0.62rem 0.72rem;
    background: #fff;
  }

  .filter-field input:focus,
  .filter-field select:focus {
    outline: none;
    border-color: #7a3d10;
    box-shadow: 0 0 0 3px rgba(122, 61, 16, 0.16);
  }

  .filter-actions {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-filter {
    min-height: 44px;
    padding: 0.75rem 1.1rem;
  }

  .quick-range {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .chip {
    border: 1px solid #cfbca4;
    background: #fff;
    color: #5b2b12;
    border-radius: 999px;
    padding: 0.44rem 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
    font-weight: 600;
  }

  .chip:hover,
  .chip.active {
    border-color: #7a3d10;
    background: #7a3d10;
    color: #fff;
  }

  .catalog-stats {
    margin-bottom: 1rem;
  }

  #filter-summary {
    margin: 0;
    font-size: 1rem;
    color: #3b2415;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .product-card[hidden] {
    display: none !important;
  }

  /* Keep catalog visible even if animation bootstrap script fails. */
  .catalog-shell,
  .catalog-shell[data-lh-reveal],
  .catalog-shell .filter-panel,
  .catalog-shell .catalog-stats,
  .catalog-shell .product-card,
  .catalog-shell .empty-state {
    opacity: 1 !important;
    transform: none !important;
  }

  .product-card {
    border: 1px solid #ecdcc8;
    border-radius: 16px;
    background: #fff;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 16px rgba(74, 49, 26, 0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 14px 30px rgba(74, 49, 26, 0.15);
  }

  .product-thumb {
    position: relative;
    display: block;
    height: 168px;
    overflow: hidden;
  }

  .product-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .product-card:hover .product-thumb img {
    transform: scale(1.05);
  }

  .thumb-code {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    background: var(--code-accent);
    color: #fff;
    padding: 0.25rem 0.5rem;
    border-radius: 7px;
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .product-meta {
    display: flex;
    flex-direction: column;
    padding: 0.9rem;
    gap: 0.55rem;
    height: 100%;
  }

  .category-tag {
    display: inline-flex;
    width: fit-content;
    padding: 0.22rem 0.48rem;
    border-radius: 999px;
    background: #f3e7d8;
    color: #633016;
    font-size: 0.74rem;
    font-weight: 700;
  }

  .product-meta h2 {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.38;
  }

  .product-meta h2 a {
    color: #2f2518;
    text-decoration: none;
  }

  .product-meta h2 a:hover {
    color: #7a3d10;
  }

  .price-meta {
    margin: 0;
    display: grid;
    gap: 0.42rem;
    font-size: 0.9rem;
  }

  .price-meta div {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    border-bottom: 1px dashed #eadbc7;
    padding-bottom: 0.3rem;
  }

  .price-meta dt {
    color: #67442d;
    font-weight: 600;
  }

  .price-meta dd {
    margin: 0;
    color: #311f13;
    font-weight: 700;
  }

  .btn-card {
    margin-top: auto;
    width: 100%;
    text-align: center;
    justify-content: center;
  }

  .empty-state {
    margin-top: 1.5rem;
    border: 1px dashed #d6c0a5;
    border-radius: 14px;
    background: #fffaf1;
    padding: 1rem;
  }

  .empty-state h3 {
    margin: 0 0 0.5rem;
    font-size: 1.06rem;
  }

  .empty-state p {
    margin: 0;
  }

  @media (max-width: 1080px) {
    .filter-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .catalog-shell {
      padding-top: 1.4rem;
    }

    .filter-panel {
      border-radius: 14px;
      padding: 0.95rem;
    }

    .filter-grid {
      grid-template-columns: 1fr;
      gap: 0.72rem;
    }

    .filter-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .quick-range {
      margin-top: 0.8rem;
    }

    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
