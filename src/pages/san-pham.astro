const productLink = 'https://mily.vn/W7mTGxXM';
---

<Layout title="Sản Phẩm | Long Hùng">
  <Header currentPage="/san-pham" />

  <!-- Hero Section -->
  <section class="products-hero">
    <div class="container">
      <h1 class="hero-title">Danh Mục Sản Phẩm</h1>
      <p class="hero-subtitle">Tổng cộng {products.length} sản phẩm</p>
    </div>
  </section>

  <!-- Products Section -->
  <section class="products-section">
    <div class="container">
      <div class="products-grid">
        {products.map((product, index) => (
          <div class="product-card" style={`--card-delay: ${index * 50}ms`}>
            <div class="product-image-wrapper">
              <img src={product.image} alt={product.name} loading="lazy" class="product-image" />
              <div class="image-overlay"></div>
            </div>
            <div class="product-info">
              <h3 class="product-name">{product.name}</h3>
              <div class="product-details">
                <div class="detail-row">
                  <span class="detail-label">Đơn vị:</span>
                  <span class="detail-value">{product.unit}</span>
                </div>
                <div class="detail-row">
                  <span class="detail-label">Giá:</span>
                  <span class="price">{product.price.toLocaleString('vi-VN')} đ</span>
                </div>
                <div class="detail-row">
                  <span class="detail-label">VAT:</span>
                  <span class="detail-value">{product.vat}</span>
                </div>
              </div>
              <a href={productLink} class="btn btn-product" target="_blank" rel="noopener noreferrer">
                <span class="btn-text">Xem chi tiết</span>
                <span class="btn-icon">→</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroSlideDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes shimmer {
    0%, 100% {
      transform: translateX(-100%);
    }
    50% {
      transform: translateX(100%);
    }
  }

  @keyframes imageZoom {
    to {
      transform: scale(1.08);
    }
  }

  @keyframes buttonPulse {
    0%, 100% {
      box-shadow: 0 4px 12px rgba(102, 0, 17, 0.25);
    }
    50% {
      box-shadow: 0 6px 20px rgba(102, 0, 17, 0.35);
    }
  }

  .products-hero {
    background: linear-gradient(135deg, rgba(102, 0, 17, 0.05) 0%, rgba(171, 106, 36, 0.05) 100%);
    padding: var(--spacing-2xl) 0;
    text-align: center;
    border-bottom: 1px solid var(--color-gray-light);
    overflow: hidden;
  }

  .hero-title {
    font-size: 2.5rem;
    color: var(--color-brown);
    margin-bottom: var(--spacing-md);
    animation: heroSlideDown 0.8s ease-out;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-gray);
    margin: 0;
    animation: heroSlideDown 0.8s ease-out 0.2s both;
  }

  .products-section {
    padding: var(--spacing-2xl) 0;
    background-color: var(--color-white);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-xl);
  }

  .product-card {
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: var(--color-white);
    animation: fadeInUp 0.6s ease-out var(--card-delay);
    opacity: 0;
    animation-fill-mode: forwards;
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .product-image-wrapper {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background-color: var(--color-bg);
    position: relative;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: block;
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .product-card:hover .product-image {
    transform: scale(1.08) rotate(1deg);
  }

  .product-card:hover .image-overlay {
    opacity: 1;
  }

  .product-info {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .product-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brown);
    margin: 0 0 var(--spacing-md) 0;
    line-height: 1.5;
    min-height: auto;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .product-details {
    margin: var(--spacing-md) 0;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--color-text);
    animation: fadeInUp 0.6s ease-out var(--card-delay);
  }

  .detail-label {
    color: var(--color-brown);
    font-weight: 600;
  }

  .detail-value {
    color: var(--color-gray);
  }

  .price {
    color: var(--color-primary) !important;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .btn-product {
    margin-top: auto;
    padding: var(--spacing-md) var(--spacing-lg);
    background-color: var(--color-primary);
    color: var(--color-white);
    text-decoration: none;
    border-radius: var(--radius-md);
    text-align: center;
    transition: all var(--transition-fast);
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    position: relative;
    overflow: hidden;
  }

  .btn-text {
    position: relative;
    z-index: 1;
  }

  .btn-icon {
    transition: transform 0.3s ease;
  }

  .btn-product:hover {
    background-color: var(--color-primary-dark);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(102, 0, 17, 0.35);
  }

  .btn-product:hover .btn-icon {
    transform: translateX(4px);
  }

  .btn-product:active {
    transform: translateY(-1px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

    .products-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: var(--spacing-lg);
    }

    .product-name {
      font-size: 0.95rem;
    }

    .detail-row {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .products-hero {
      padding: var(--spacing-xl) 0;
    }

    .hero-title {
      font-size: 1.75rem;
    }

    .products-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .product-image-wrapper {
      height: 150px;
    }

    .product-info {
      padding: var(--spacing-md);
    }

    .btn-product {
      padding: var(--spacing-md);
      font-size: 0.9rem;
    }
  }
</style>
