{
  "name": "longhung-website",
  "compatibility_date": "2026-06-23",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "e955f9f35477453abcf721ab01b545c8"
