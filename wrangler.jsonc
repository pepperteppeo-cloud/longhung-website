  "routes": [
    {
      "pattern": "vpplonghung.com/*",
      "zone_name": "vpplonghung.com"
    },
    {
      "pattern": "*.vpplonghung.com/*",
      "zone_name": "vpplonghung.com"
    }
  ]
}
